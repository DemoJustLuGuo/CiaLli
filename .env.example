# ============================================
# CiaLli Unified Environment
# ============================================

# ============================================
# Public Entry
# ============================================
APP_PUBLIC_BASE_URL=https://localhost
# 可选：公开资源基础地址。留空则统一走站内 BFF 代理（/api/v1/public/assets/:id）
PUBLIC_ASSET_BASE_URL=

# ============================================
# Directus
# ============================================
DIRECTUS_URL=http://127.0.0.1:8055
# 由安装器在管理员创建后自动回填；手动部署时需提供可用的 Directus 静态 token
DIRECTUS_STATIC_TOKEN=
DIRECTUS_SECRET=change-me

# ============================================
# PostgreSQL / Redis / MinIO
# ============================================
POSTGRES_USER=dbu_example
POSTGRES_DB=directus
POSTGRES_PASSWORD=change-me
REDIS_URL=redis://127.0.0.1:6379/0
MINIO_ROOT_USER=minio_example
MINIO_ROOT_PASSWORD=change-me

# ============================================
# Installer Admin Bootstrap
# 仅安装期与运维排障使用；运行时服务本身不依赖以下两项
# ============================================
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=change-me

# ============================================
# Directus Storage Locations
# ============================================
STORAGE_S3_KEY=s3_example
STORAGE_S3_SECRET=change-me

# ============================================
# Application Secrets
# ============================================
# Bangumi AccessToken 加密密钥
BANGUMI_TOKEN_ENCRYPTION_KEY=

# ============================================
# AI Summary Worker
# ============================================
AI_SUMMARY_INTERNAL_SECRET=
