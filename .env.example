# ============================================
# CiaLli Unified Environment
# ============================================

# ============================================
# Public Entry
# ============================================
# 站点公网根地址，同时驱动 Astro site、sitemap/RSS/canonical 与 Caddy 入口。
# 仅支持根路径 URL：允许 http(s)://host[:port] 或 http(s)://ip[:port]，不允许 path/query/hash。
APP_PUBLIC_BASE_URL=http://localhost
# 可选：Caddy 追加站点地址。生产通常留空；本地 Docker override 默认使用 http:// 允许局域网 HTTP 访问。
CADDY_ADDITIONAL_SITE_ADDRESS=
# 可选：公开资源基础地址。留空则统一走站内 BFF 代理（/api/v1/public/assets/:id）
PUBLIC_ASSET_BASE_URL=

# ============================================
# Directus
# ============================================
DIRECTUS_URL=http://127.0.0.1:8055
# Directus 宿主机回环端口，多实例部署时可改为 8056/8057 等。
DIRECTUS_HOST_BIND=127.0.0.1
DIRECTUS_HOST_PORT=8055
# 由安装器在服务账号创建后自动回填；手动部署时需分别提供 web / worker 的 Directus 静态 token
DIRECTUS_WEB_STATIC_TOKEN=
DIRECTUS_WORKER_STATIC_TOKEN=
DIRECTUS_SECRET=change-me

# ============================================
# PostgreSQL / Redis / MinIO
# ============================================
POSTGRES_USER=dbu_example
POSTGRES_DB=directus
POSTGRES_PASSWORD=change-me
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_HOST_BIND=127.0.0.1
REDIS_HOST_PORT=6379
MINIO_ROOT_USER=minio_example
MINIO_ROOT_PASSWORD=change-me
MINIO_CONSOLE_HOST_BIND=127.0.0.1
MINIO_CONSOLE_HOST_PORT=9001

# ============================================
# Installer Admin Bootstrap
# 仅安装期与运维排障使用；运行时服务本身不依赖以下两项
# ============================================
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=change-me

# ============================================
# Directus Storage Locations
# ============================================
STORAGE_S3_KEY=s3_example
STORAGE_S3_SECRET=change-me

# ============================================
# Application Secrets
# ============================================
# 应用密钥加密主密钥
APP_SECRET_ENCRYPTION_KEY=

# ============================================
# AI Summary Worker
# ============================================
AI_SUMMARY_INTERNAL_SECRET=
AI_SUMMARY_PROVIDER_TIMEOUT_MS=90000
FILE_GC_INTERVAL_MS=900000
FILE_GC_RETENTION_HOURS=168
FILE_GC_QUARANTINE_DAYS=7
FILE_GC_BATCH_SIZE=200
FILE_GC_DELETE_MAX_ATTEMPTS=6
FILE_DETACH_JOB_INTERVAL_MS=60000
FILE_DETACH_JOB_BATCH_SIZE=50
FILE_DETACH_JOB_LEASE_SECONDS=300
FILE_LIFECYCLE_RECONCILE_INTERVAL_MS=86400000
FILE_REFERENCE_SHADOW_INTERVAL_MS=86400000
