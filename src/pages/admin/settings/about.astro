---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import AdminLayout from "@layouts/AdminLayout.astro";
import AboutEditorSection from "@/components/admin/settings/AboutEditorSection.astro";
import "@/styles/markdown.css";
import "@/styles/markdown-extend.styl";

export const prerender = false;
---

<AdminLayout
  title={i18n(I18nKey.adminAboutTitle)}
  description={i18n(I18nKey.adminAboutDescription)}
>
  <div
    data-enter-skeleton-page="admin-about-settings"
    data-enter-skeleton-target="admin-about-settings"
  >
    <div data-enter-skeleton-inline-content class="space-y-4 text-75">
      <section class="card-base px-9 py-6 rounded-(--radius-large)">
        <h1
          class="text-4xl font-bold text-black/90 dark:text-white/90 mb-2 relative
            before:w-1 before:h-8 before:rounded-md before:bg-(--primary)
            before:absolute before:top-1/2 before:-translate-y-1/2 before:-left-4"
        >
          {i18n(I18nKey.adminAboutTitle)}
        </h1>
        <p class="text-base text-70">
          {i18n(I18nKey.adminAboutDescription)}
        </p>
      </section>
      <AboutEditorSection />
    </div>

    <div
      data-enter-skeleton-inline-placeholder
      aria-hidden="true"
      class="space-y-4"
    >
      <section class="card-base px-9 py-6 rounded-(--radius-large) space-y-3">
        <div
          class="md3-skeleton-text"
          style="--skeleton-width: 34%; --skeleton-height: 2rem;"
        >
        </div>
        <div class="md3-skeleton-text" style="--skeleton-width: 62%;"></div>
      </section>

      <section class="card-base p-8 rounded-(--radius-large) space-y-4">
        <div class="space-y-2">
          <div
            class="md3-skeleton-text"
            style="--skeleton-width: 22%; --skeleton-height: 0.875rem;"
          >
          </div>
          <div class="md3-skeleton-block h-10 rounded-lg"></div>
        </div>
        <div class="space-y-2">
          <div
            class="md3-skeleton-text"
            style="--skeleton-width: 24%; --skeleton-height: 0.875rem;"
          >
          </div>
          <div class="md3-skeleton-block h-20 rounded-lg"></div>
        </div>
        <div class="md3-skeleton-block h-64 rounded-xl"></div>
      </section>
    </div>
  </div>
</AdminLayout>
