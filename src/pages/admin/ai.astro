---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import AdminLayout from "@layouts/AdminLayout.astro";
import SettingsField from "@/components/admin/settings/SettingsField.astro";
---

<AdminLayout
  title={i18n(I18nKey.adminAiPageTitle)}
  description={i18n(I18nKey.adminAiPageDescription)}
>
  <div
    data-enter-skeleton-page="admin-ai"
    data-enter-skeleton-target="admin-ai"
    data-ui-density="settings-console"
    data-admin-ai-settings-root
    data-endpoint="/api/v1/admin/ai/settings"
    data-saved-text={i18n(I18nKey.adminAiSettingsSaved)}
    data-failed-text={i18n(I18nKey.adminAiSettingsSaveFailed)}
  >
    <div data-enter-skeleton-inline-content class="space-y-4 text-75">
      <section
        class="card-base settings-console-card settings-console-header-card rounded-(--radius-large)"
      >
        <h1
          class="settings-console-header-title text-4xl font-bold text-90 mb-2 relative
            before:w-1 before:h-8 before:rounded-md before:bg-(--primary)
            before:absolute before:top-1/2 before:-translate-y-1/2 before:-left-4"
        >
          {i18n(I18nKey.adminAiPageTitle)}
        </h1>
        <p class="settings-console-header-copy text-base text-70">
          {i18n(I18nKey.adminAiPageIntro)}
        </p>
      </section>

      <section
        class="card-base settings-console-card rounded-(--radius-large) space-y-5"
      >
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div>
            <h2 class="text-2xl font-semibold text-90">
              {i18n(I18nKey.adminAiSectionConnection)}
            </h2>
            <p class="text-sm text-60 mt-1">
              OpenAI-compatible Chat Completions endpoint.
            </p>
          </div>
          <span
            id="admin-ai-api-key-state"
            class="inline-flex items-center rounded-full border border-(--line-divider) px-3 py-1 text-xs text-60"
            data-configured-label={i18n(I18nKey.adminAiApiKeyConfigured)}
            data-missing-label={i18n(I18nKey.adminAiApiKeyMissing)}
          >
            {i18n(I18nKey.adminAiApiKeyMissing)}
          </span>
        </div>

        <form id="admin-ai-settings-form" class="space-y-4">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            <label
              class="flex items-center gap-3 rounded-xl border border-(--line-divider) p-4 text-sm text-75"
            >
              <input
                id="admin-ai-enabled"
                type="checkbox"
                class="toggle-checkbox"
              />
              <span class="toggle-track"><span class="toggle-knob"></span></span
              >
              <span>{i18n(I18nKey.adminAiPageTitle)}</span>
            </label>
            <label
              class="flex items-center gap-3 rounded-xl border border-(--line-divider) p-4 text-sm text-75"
            >
              <input
                id="admin-ai-article-summary-enabled"
                type="checkbox"
                class="toggle-checkbox"
              />
              <span class="toggle-track"><span class="toggle-knob"></span></span
              >
              <span>{i18n(I18nKey.adminAiFeatureArticleSummary)}</span>
            </label>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            <SettingsField label={i18n(I18nKey.adminAiConnectionApiBaseUrl)}>
              <input
                id="admin-ai-base-url"
                class="w-full rounded-lg border border-(--line-divider) px-3.5 py-2.5 bg-transparent text-90 placeholder:text-50"
                placeholder="https://api.openai.com/v1"
              />
            </SettingsField>
            <SettingsField label={i18n(I18nKey.adminAiConnectionModel)}>
              <input
                id="admin-ai-model"
                class="w-full rounded-lg border border-(--line-divider) px-3.5 py-2.5 bg-transparent text-90 placeholder:text-50"
                placeholder="gpt-4o-mini"
              />
            </SettingsField>
            <SettingsField label={i18n(I18nKey.adminAiConnectionApiKey)}>
              <input
                id="admin-ai-api-key"
                type="password"
                autocomplete="new-password"
                class="w-full rounded-lg border border-(--line-divider) px-3.5 py-2.5 bg-transparent text-90 placeholder:text-50"
                placeholder={i18n(I18nKey.adminAiPlaceholderApiKey)}
              />
            </SettingsField>
          </div>

          <div class="flex flex-wrap items-center gap-3 pt-2">
            <button
              id="admin-ai-save"
              type="submit"
              class="px-4 h-10 rounded-lg bg-(--primary) text-white text-sm font-medium"
            >
              {i18n(I18nKey.adminAiSaveSettings)}
            </button>
            <button
              id="admin-ai-clear-api-key"
              type="button"
              class="px-4 h-10 rounded-lg border border-(--line-divider) text-sm text-75 hover:bg-(--btn-plain-bg-hover) transition"
            >
              {i18n(I18nKey.adminAiClearApiKey)}
            </button>
            <span id="admin-ai-message" class="text-sm text-60"></span>
          </div>
        </form>
      </section>

      <section
        class="card-base settings-console-card rounded-(--radius-large) space-y-3"
      >
        <h2 class="text-2xl font-semibold text-90">
          {i18n(I18nKey.adminAiSectionAutomation)}
        </h2>
        <p class="text-sm text-70 leading-6">
          {i18n(I18nKey.adminAiAutomationDescription)}
        </p>
      </section>
    </div>
  </div>

  <script>
    import "@/scripts/admin/ai-settings-page";
  </script>
</AdminLayout>
