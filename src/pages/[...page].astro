---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import HomeFeedPage from "@components/home/HomeFeedPage.astro";
import { getSessionUser } from "@/server/auth/session";
import {
  DIRECTUS_ACCESS_COOKIE_NAME,
  DIRECTUS_REFRESH_COOKIE_NAME,
} from "@/server/directus-auth";
import { buildHomeFeed } from "@/server/recommendation/home-feed";
import type { HomeFeedItem } from "@/server/recommendation/home-feed.types";

export const prerender = false;

const rawPagePath = Astro.params.page || "";

// 重定向旧分页 URL
if (rawPagePath) {
  const isOldPagination =
    /^\d+$/.test(rawPagePath) || /^page\/\d+$/i.test(rawPagePath);
  if (isOldPagination) {
    return Astro.redirect("/", 301);
  }
  // 非分页路径 → 404
  Astro.response.status = 404;
}

let homeFeedItems: HomeFeedItem[] = [];
const invalidPath = Boolean(rawPagePath);
let sessionUserId: string | null = null;
const deleteAdminLabelI18n = i18n(I18nKey.interactionCommonDeleteAdmin);
const hasSessionCookie = Boolean(
  Astro.cookies.get(DIRECTUS_ACCESS_COOKIE_NAME)?.value ||
  Astro.cookies.get(DIRECTUS_REFRESH_COOKIE_NAME)?.value,
);

if (!invalidPath) {
  try {
    const sessionUser = await getSessionUser(Astro);
    sessionUserId = sessionUser?.id ?? null;
    const homeFeed = await buildHomeFeed({
      viewerId: sessionUser?.id ?? null,
      limit: 20,
      outputLimit: 60,
      articleCandidateLimit: 80,
      diaryCandidateLimit: 60,
    });
    homeFeedItems = homeFeed.items;
  } catch (error) {
    console.error("[home] failed to load mixed feed:", error);
  }
}

if (!invalidPath) {
  if (hasSessionCookie || sessionUserId) {
    Astro.response.headers.set("Cache-Control", "private, no-store");
  } else {
    Astro.response.headers.set(
      "Cache-Control",
      "public, s-maxage=60, stale-while-revalidate=300",
    );
  }
}
---

<MainGridLayout>
  {
    invalidPath ? (
      <div class="card-base p-8 rounded-(--radius-large)">
        <h1 class="text-2xl font-bold mb-2">
          {i18n(I18nKey.coreNotFoundTitle)}
        </h1>
        <p class="text-70">{i18n(I18nKey.contentPageNotFoundPathCheck)}</p>
      </div>
    ) : (
      <div class="home-layout">
        <div
          id="home-feed-runtime-config"
          class="hidden"
          data-delete-admin-label={deleteAdminLabelI18n}
        />
        <div class="min-w-0">
          {homeFeedItems.length === 0 ? (
            <div class="card-base p-8 rounded-(--radius-large) text-70">
              {i18n(I18nKey.contentPageNoPublicPosts)}
            </div>
          ) : (
            <HomeFeedPage items={homeFeedItems} maxAnimationIndex={15} />
          )}

          {/* 无限滚动哨兵 */}
          <div id="infinite-scroll-sentinel" class="h-1" />
          <div
            id="scroll-loading"
            class="hidden text-center py-4 text-sm text-60"
          >
            {i18n(I18nKey.interactionCommonLoading)}
          </div>
        </div>
        {/* 右侧占位，与归档页筛选面板等宽 */}
        <div class="home-sidebar-placeholder" />
      </div>
    )
  }
</MainGridLayout>

<style>
  .home-layout {
    display: grid;
    grid-template-columns: 1fr 17.5rem;
    gap: 1rem;
    align-items: start;
  }
  .home-sidebar-placeholder {
    /* 纯占位，不渲染任何内容 */
  }
</style>

<script>
  type HomeRuntimeWindow = Window &
    typeof globalThis & {
      __homeScrollCleanup?: () => void;
    };
  type HomeFeedAuthor = {
    id?: string;
    name?: string;
    username?: string;
    display_name?: string;
  };
  type HomeFeedArticleItem = {
    type: "article";
    id: string;
    entry: {
      url: string;
      data: {
        title: string;
        description?: string;
        tags?: string[];
        category?: string;
        author_id: string;
        author?: HomeFeedAuthor;
        article_id?: string;
        comment_count?: number;
        like_count?: number;
        published: string | Date;
      };
    };
  };
  type HomeFeedDiaryItem = {
    type: "diary";
    id: string;
    entry: {
      id: string;
      short_id?: string | null;
      content?: string;
      author_id: string;
      author?: HomeFeedAuthor;
      comment_count?: number;
      like_count?: number;
      date_created?: string;
      date_updated?: string;
    };
    publishedAt?: string | Date;
  };
  type HomeFeedItem = HomeFeedArticleItem | HomeFeedDiaryItem;

  const BATCH_SIZE = 5;

  function resolveDeleteAdminLabel(): string {
    const configEl = document.getElementById("home-feed-runtime-config");
    if (!(configEl instanceof HTMLElement)) {
      return "Delete (Admin)";
    }
    const value = String(configEl.dataset.deleteAdminLabel || "").trim();
    return value || "Delete (Admin)";
  }

  const deleteAdminLabel = resolveDeleteAdminLabel();

  function escapeHtml(input: string): string {
    return input
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");
  }

  function normalizeAuthorHandle(
    author: HomeFeedAuthor | undefined,
    fallbackId: string,
  ): string {
    const raw = String(author?.username || author?.name || "")
      .trim()
      .replace(/^@+/, "");
    if (raw) {
      return raw;
    }
    return `user-${String(fallbackId || "").slice(0, 8)}`;
  }

  function normalizeAuthorDisplayName(
    author: HomeFeedAuthor | undefined,
    fallbackHandle: string,
  ): string {
    const displayName = String(
      author?.display_name || author?.name || "",
    ).trim();
    return displayName || fallbackHandle;
  }

  function formatDateMeta(value: string | Date | undefined): {
    display: string;
    year: string;
    month: string;
    day: string;
  } {
    const parsed = new Date(value || "");
    const safeDate = Number.isNaN(parsed.getTime()) ? new Date(0) : parsed;
    const year = String(safeDate.getFullYear());
    const month = String(safeDate.getMonth() + 1).padStart(2, "0");
    const day = String(safeDate.getDate()).padStart(2, "0");
    return {
      display: `${year}/${month}/${day}`,
      year,
      month: `${year}-${month}`,
      day: `${year}-${month}-${day}`,
    };
  }

  function renderArticleCard(item: HomeFeedArticleItem): string {
    const data = item.entry.data;
    const tags = Array.isArray(data.tags) ? data.tags : [];
    const category = String(data.category || "");
    const title = escapeHtml(String(data.title || "Untitled"));
    const excerpt = escapeHtml(
      String(data.description || "").trim() || "No summary",
    );
    const articleId = String(data.article_id || item.id || "");
    const authorId = String(data.author_id || "");
    const authorHandle = normalizeAuthorHandle(data.author, authorId);
    const authorDisplayName = escapeHtml(
      normalizeAuthorDisplayName(data.author, authorHandle),
    );
    const dateMeta = formatDateMeta(data.published);
    const likeCount = Math.max(0, Number(data.like_count || 0));
    const commentCount = Math.max(0, Number(data.comment_count || 0));
    const postUrl = escapeHtml(String(item.entry.url || `/posts/${item.id}`));
    return `
      <div class="post-list-item" data-year="${escapeHtml(dateMeta.year)}" data-month="${escapeHtml(dateMeta.month)}" data-day="${escapeHtml(dateMeta.day)}" data-tags="${escapeHtml(JSON.stringify(tags))}" data-category="${escapeHtml(category)}" data-author-id="${escapeHtml(authorId)}" data-author-handle="${escapeHtml(authorHandle)}" data-content-type="article">
        <article class="card-base rounded-(--radius-large) p-6" data-post-card data-article-id="${escapeHtml(articleId)}" data-author-id="${escapeHtml(authorId)}" data-author-handle="${escapeHtml(authorHandle)}">
          <a href="${postUrl}" class="block mb-3 text-2xl font-bold text-90 hover:text-(--primary)">${title}</a>
          <p class="mb-4 text-75 line-clamp-2">${excerpt}</p>
          <div class="flex items-center justify-between gap-3 text-sm text-60">
            <div class="min-w-0 truncate">
              <a href="/${escapeHtml(authorHandle)}" class="text-90 hover:text-(--primary)">${authorDisplayName}</a>
              <span class="mx-1">·</span>
              <span>${escapeHtml(dateMeta.display)}</span>
            </div>
            <div class="flex items-center gap-4 shrink-0">
              <button type="button" class="inline-flex items-center gap-1.5 text-50 hover:text-(--primary) post-card-action-btn" data-action="toggle-like" aria-label="Toggle like">
                <span>Like</span>
                <span data-like-count>${likeCount}</span>
              </button>
              <a href="${postUrl}#comment-root" class="inline-flex items-center gap-1.5 text-50 hover:text-(--primary)">
                <span>Comment</span>
                <span>${commentCount}</span>
              </a>
              <details class="relative post-card-menu">
                <summary class="list-none cursor-pointer">⋯</summary>
                <div class="absolute right-0 bottom-full mb-2 z-30 min-w-[10rem] rounded-xl border border-black/5 dark:border-white/10 bg-(--float-panel-bg) p-1.5 shadow-xl dark:shadow-none">
                  <button type="button" class="hidden w-full text-left px-3 py-2 text-sm rounded-lg text-red-500 hover:text-red-500 hover:bg-(--btn-plain-bg-hover) post-card-action-btn transition-colors" data-action="delete-own-article">Delete Article</button>
                  <button type="button" class="hidden w-full text-left px-3 py-2 text-sm rounded-lg text-red-500 hover:text-red-500 hover:bg-(--btn-plain-bg-hover) post-card-action-btn transition-colors" data-action="delete-admin-article">${escapeHtml(deleteAdminLabel)}</button>
                  <button type="button" class="w-full text-left px-3 py-2 text-sm rounded-lg text-black/75 dark:text-white/75 hover:text-(--primary) hover:bg-(--btn-plain-bg-hover) post-card-action-btn transition-colors" data-action="block-user">Block User</button>
                </div>
              </details>
            </div>
          </div>
        </article>
      </div>
    `;
  }

  function renderDiaryCard(item: HomeFeedDiaryItem): string {
    const entry = item.entry;
    const authorId = String(entry.author_id || "");
    const authorHandle = normalizeAuthorHandle(entry.author, authorId);
    const authorDisplayName = escapeHtml(
      normalizeAuthorDisplayName(entry.author, authorHandle),
    );
    const diaryId = String(entry.id || item.id || "");
    const routeId = String(entry.short_id || diaryId || "");
    const diaryUrl = `/${escapeHtml(authorHandle)}/diary/${escapeHtml(routeId)}`;
    const dateMeta = formatDateMeta(
      entry.date_created || entry.date_updated || item.publishedAt,
    );
    const likeCount = Math.max(0, Number(entry.like_count || 0));
    const commentCount = Math.max(0, Number(entry.comment_count || 0));
    const excerpt = escapeHtml(
      String(entry.content || "")
        .replace(/<[^>]+>/g, " ")
        .replace(/\s+/g, " ")
        .trim()
        .slice(0, 120) || "No content",
    );
    return `
      <div class="post-list-item diary-list-item" data-year="${escapeHtml(dateMeta.year)}" data-month="${escapeHtml(dateMeta.month)}" data-day="${escapeHtml(dateMeta.day)}" data-tags="[]" data-category="" data-author-id="${escapeHtml(authorId)}" data-author-handle="${escapeHtml(authorHandle)}" data-content-type="diary">
        <article class="card-base rounded-(--radius-large) p-6" data-diary-card data-diary-id="${escapeHtml(diaryId)}" data-author-id="${escapeHtml(authorId)}" data-author-handle="${escapeHtml(authorHandle)}">
          <a href="${diaryUrl}" class="block mb-3 text-lg font-semibold text-90 hover:text-(--primary)">${excerpt}</a>
          <div class="flex items-center justify-between gap-3 text-sm text-60">
            <div class="min-w-0 truncate">
              <a href="/${escapeHtml(authorHandle)}" class="text-90 hover:text-(--primary)">${authorDisplayName}</a>
              <span class="mx-1">·</span>
              <span>${escapeHtml(dateMeta.display)}</span>
            </div>
            <div class="flex items-center gap-4 shrink-0">
              <button type="button" class="inline-flex items-center gap-1.5 text-50 hover:text-(--primary) post-card-action-btn" data-action="toggle-like" aria-label="Toggle like">
                <span>Like</span>
                <span data-like-count>${likeCount}</span>
              </button>
              <a href="${diaryUrl}#comment-root" class="inline-flex items-center gap-1.5 text-50 hover:text-(--primary)">
                <span>Comment</span>
                <span>${commentCount}</span>
              </a>
              <details class="relative post-card-menu">
                <summary class="list-none cursor-pointer">⋯</summary>
                <div class="absolute right-0 bottom-full mb-2 z-30 min-w-[10rem] rounded-xl border border-black/5 dark:border-white/10 bg-(--float-panel-bg) p-1.5 shadow-xl dark:shadow-none">
                  <button type="button" class="hidden w-full text-left px-3 py-2 text-sm rounded-lg text-red-500 hover:text-red-500 hover:bg-(--btn-plain-bg-hover) post-card-action-btn transition-colors" data-action="delete-own-diary">Delete Diary</button>
                  <button type="button" class="hidden w-full text-left px-3 py-2 text-sm rounded-lg text-red-500 hover:text-red-500 hover:bg-(--btn-plain-bg-hover) post-card-action-btn transition-colors" data-action="delete-admin-diary">${escapeHtml(deleteAdminLabel)}</button>
                  <button type="button" class="w-full text-left px-3 py-2 text-sm rounded-lg text-black/75 dark:text-white/75 hover:text-(--primary) hover:bg-(--btn-plain-bg-hover) post-card-action-btn transition-colors" data-action="block-user">Block User</button>
                </div>
              </details>
            </div>
          </div>
        </article>
      </div>
    `;
  }

  function renderFeedItems(items: HomeFeedItem[]): string {
    return items
      .map((item) =>
        item.type === "article"
          ? renderArticleCard(item as HomeFeedArticleItem)
          : renderDiaryCard(item as HomeFeedDiaryItem),
      )
      .join("");
  }

  function initHomeInfiniteScroll(): void {
    const rw = window as HomeRuntimeWindow;
    rw.__homeScrollCleanup?.();

    const container = document.querySelector(".home-layout");
    if (!container) return;

    const postList = document.getElementById("post-list-container");
    if (!postList) {
      return;
    }
    const items = postList.querySelectorAll<HTMLElement>(".post-list-item");
    const sentinel = document.getElementById("infinite-scroll-sentinel");
    const loadingEl = document.getElementById("scroll-loading");

    if (!items.length || !sentinel) {
      sentinel?.classList.add("hidden");
      return;
    }

    let loadedCount = items.length;
    let hasMore = true;
    let isLoading = false;

    const loadNextBatch = async (): Promise<void> => {
      if (!hasMore || isLoading) {
        return;
      }
      isLoading = true;
      loadingEl?.classList.remove("hidden");
      try {
        const response = await fetch(
          `/api/v1/public/home-feed?offset=${loadedCount}&limit=${BATCH_SIZE}`,
          {
            credentials: "include",
            headers: {
              Accept: "application/json",
            },
          },
        );
        const data = (await response.json().catch(() => null)) as {
          ok?: boolean;
          items?: HomeFeedItem[];
          has_more?: boolean;
          next_offset?: number;
        } | null;
        if (!response.ok || !data?.ok || !Array.isArray(data.items)) {
          return;
        }
        if (data.items.length === 0) {
          hasMore = false;
          observer.disconnect();
          sentinel.classList.add("hidden");
          return;
        }

        const html = renderFeedItems(data.items);
        if (html) {
          const fragment = document
            .createRange()
            .createContextualFragment(html);
          postList.appendChild(fragment);
        }
        loadedCount =
          typeof data.next_offset === "number"
            ? data.next_offset
            : loadedCount + data.items.length;
        hasMore = Boolean(data.has_more);
        if (!hasMore) {
          observer.disconnect();
          sentinel.classList.add("hidden");
        }
      } catch (error) {
        console.error("[home] load next feed batch failed:", error);
      } finally {
        isLoading = false;
        loadingEl?.classList.add("hidden");
      }
    };

    const observer = new IntersectionObserver(
      (entries) => {
        if (!entries[0].isIntersecting || !hasMore) {
          return;
        }
        void loadNextBatch();
      },
      { rootMargin: "200px" },
    );

    observer.observe(sentinel);

    rw.__homeScrollCleanup = () => {
      observer.disconnect();
      rw.__homeScrollCleanup = undefined;
    };
  }

  initHomeInfiniteScroll();
  document.addEventListener("astro:after-swap", initHomeInfiniteScroll);
</script>
