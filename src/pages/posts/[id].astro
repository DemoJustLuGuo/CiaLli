---
import Comment from "@components/comment/index.astro";
import ContentNotVisible from "@components/misc/ContentNotVisible.astro";
import ArticleShareDialog from "@components/misc/ArticleShareDialog.astro";
import Profile from "@components/widget/Profile.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import ExternalImage from "@components/misc/ExternalImage.astro";
import Markdown from "@components/misc/Markdown.astro";
import PasswordProtection from "@components/PasswordProtection.astro";
import ResponsiveImage from "@components/misc/ResponsiveImage.astro";
import { defaultSiteSettings } from "@/config";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import {
  loadArticleDetailViewData,
  resolveArticleDetailCacheControl,
  resolveArticleDetailRoute,
} from "@/server/application/public/article-detail-page.service";
import { renderMarkdown } from "@/server/markdown/render";
import {
  buildDirectusAssetUrl,
  buildPublicAssetUrl,
} from "@/server/directus-auth";
import {
  loadArticleInteractionSnapshot,
  isSpecialArticleSlug,
  loadArticleByShortIdLoose,
  loadArticleBySlugLoose,
  loadPublicArticleByShortId,
  loadPublicArticleBySlug,
  safeCsv,
} from "@/server/api/v1/shared";
import { isShortId } from "@/server/utils/short-id";
import { getAuthorBundle } from "@/server/api/v1/shared/author-cache";
import {
  loadPublicProfileByUserId,
  readAuthor,
} from "@/server/api/v1/public-data";
import {
  loadProfileForViewerByUserId,
  profileToSidebarData,
} from "@/server/api/v1/public-data";
import {
  runWithDirectusPublicAccess,
  runWithDirectusServiceAccess,
  runWithDirectusUserAccess,
} from "@/server/directus/client";
import { readLatestArticleSummaryJob } from "@/server/ai-summary/jobs";
import { getSessionAccessToken, getSessionUser } from "@/server/auth/session";
import { getResolvedSiteSettings } from "@/server/site-settings/service";
import type { AppArticle } from "@/types/app";
import { buildOwnerArticlePasswordStorageKeys } from "@/utils/protected-content";
import type { SharePosterPayload } from "@/utils/share-poster";
import {
  buildSiteDateFormatContext,
  formatSiteDateTime,
} from "@/utils/date-utils";
import { hasEditorSaveFreshnessParam } from "@/utils/editor-save-freshness";
import DetailActionFloat from "@components/control/DetailActionFloat.astro";

const rawId = (Astro.params.id || "").replace(/^\/+|\/+$/g, "");
const bypassPublicCache = hasEditorSaveFreshnessParam(Astro.url);

let article: {
  id: string;
  short_id: string | null;
  title: string;
  slug: string | null;
  summary: string | null;
  summary_source: "none" | "manual" | "ai";
  body_markdown: string;
  cover_file: string | null;
  cover_url: string | null;
  tags: string[];
  category: string | null;
  allow_comments: boolean;
  status: "draft" | "published" | "archived";
  is_public: boolean;
  date_created: string | null;
  date_updated: string | null;
  author?: {
    id?: string;
    name?: string;
    display_name?: string;
    avatar_url?: string;
  };
} | null = null;
let articleHtml = "";
let encryptedBody = "";
let articleLikeCount = 0;
let articleCommentCount = 0;
let articleLikedByViewer = false;
let viewerIsOwner = false;
let ownerPasswordStorageKeys: string[] = [];
let sessionUserId: string | null = null;
let articleSupportsPublicInteraction = false;
let articleCacheScope: "public" | "private" = "public";
let articleAiSummaryJobStatus:
  | "pending"
  | "processing"
  | "succeeded"
  | "failed"
  | "canceled"
  | "skipped"
  | null = null;
let showPendingAiSummarySkeleton = false;
const resolvedSiteSettings =
  Astro.locals.siteSettings ?? (await getResolvedSiteSettings());
const siteDateContext = buildSiteDateFormatContext(resolvedSiteSettings);

function resolvePublicArticleByRoute(
  routeId: string,
): Promise<AppArticle | null> {
  if (isShortId(routeId)) {
    return loadPublicArticleByShortId(routeId);
  }
  if (isSpecialArticleSlug(routeId)) {
    return loadPublicArticleBySlug(routeId);
  }
  return Promise.resolve(null);
}

function resolveOwnerArticleByRoute(
  routeId: string,
): Promise<AppArticle | null> {
  if (isShortId(routeId)) {
    return loadArticleByShortIdLoose(routeId);
  }
  if (isSpecialArticleSlug(routeId)) {
    return loadArticleBySlugLoose(routeId);
  }
  return Promise.resolve(null);
}

if (rawId) {
  try {
    const resolvedArticle = await resolveArticleDetailRoute({
      routeId: rawId,
      preferOwner: bypassPublicCache,
      loadPublicArticleByRoute: async (routeId) =>
        await runWithDirectusPublicAccess(
          async () => await resolvePublicArticleByRoute(routeId),
        ),
      loadSessionUser: async () => await getSessionUser(Astro),
      getSessionAccessToken: () => getSessionAccessToken(Astro),
      loadOwnerArticleByRoute: async (routeId, accessToken) =>
        await runWithDirectusUserAccess(
          accessToken,
          async () => await resolveOwnerArticleByRoute(routeId),
        ),
    });

    articleCacheScope = bypassPublicCache
      ? "private"
      : resolvedArticle.cacheScope;
    sessionUserId = resolvedArticle.sessionUserId;

    if (resolvedArticle.mode === "public" || resolvedArticle.mode === "owner") {
      const rawArticle = resolvedArticle.article;
      const loadViewData = async () =>
        await loadArticleDetailViewData({
          article: rawArticle,
          mode: resolvedArticle.mode,
          sessionUserId,
          loadAuthorBundle: async (authorId) =>
            await getAuthorBundle([authorId]),
          loadArticleInteractionSnapshot,
          loadPublicProfileByUserId,
          loadProfileForViewerByUserId,
          renderArticleMarkdown: async (bodyMarkdown) =>
            await renderMarkdown(bodyMarkdown, {
              target: "page",
            }),
          loadLatestAiSummaryJob: async (articleId) =>
            await runWithDirectusServiceAccess(
              async () => await readLatestArticleSummaryJob(articleId),
            ),
        });

      const viewData =
        resolvedArticle.mode === "owner"
          ? await runWithDirectusUserAccess(
              getSessionAccessToken(Astro),
              loadViewData,
            )
          : await runWithDirectusPublicAccess(loadViewData);

      article = {
        ...rawArticle,
        tags: safeCsv(rawArticle.tags),
        author: readAuthor(viewData.authorMap, rawArticle.author_id),
      };
      articleLikeCount = viewData.interaction.likeCount;
      articleCommentCount = viewData.interaction.commentCount;
      articleLikedByViewer = viewData.interaction.viewerLiked;
      viewerIsOwner = Boolean(
        resolvedArticle.mode === "owner" &&
        sessionUserId &&
        rawArticle.author_id === sessionUserId,
      );
      articleSupportsPublicInteraction = viewData.isPubliclyVisible;
      articleAiSummaryJobStatus = viewData.aiSummaryJobStatus;
      showPendingAiSummarySkeleton = viewData.showPendingAiSummarySkeleton;

      if (viewData.isEncryptedBody) {
        encryptedBody = viewData.encryptedBody;
        ownerPasswordStorageKeys = buildOwnerArticlePasswordStorageKeys({
          id: rawArticle.id,
          shortId: rawArticle.short_id,
          slug: rawArticle.slug,
        });
      } else {
        articleHtml = viewData.articleHtml;
      }
      if (viewData.authorProfile) {
        Astro.locals.sidebarProfile = profileToSidebarData(
          viewData.authorProfile,
        );
      }
    } else {
      Astro.response.status = 404;
    }
  } catch (error) {
    console.error("[posts] failed to load article:", error);
    Astro.response.status = 500;
  }
} else {
  Astro.response.status = 404;
}

const responseStatus = Astro.response.status ?? 200;
const cacheControl = resolveArticleDetailCacheControl({
  responseStatus,
  cacheScope: articleCacheScope,
});
if (cacheControl) {
  Astro.response.headers.set("Cache-Control", cacheControl);
}

const hasCoverFile = Boolean(article?.cover_file);
const articleVisibleToPublic =
  article?.status === "published" && article?.is_public === true;
const coverUrl = article?.cover_url
  ? article.cover_url
  : article?.cover_file
    ? (articleVisibleToPublic ? buildPublicAssetUrl : buildDirectusAssetUrl)(
        article.cover_file,
        {
          width: 1600,
          height: 900,
          fit: "cover",
        },
      )
    : null;
const ogImageUrl =
  articleVisibleToPublic && coverUrl
    ? new URL(coverUrl, Astro.url).toString()
    : null;

const ownerOnlyNotice = viewerIsOwner
  ? article?.status === "draft"
    ? i18n(I18nKey.contentArticleOwnerDraftNotice)
    : article && !articleVisibleToPublic
      ? i18n(I18nKey.contentArticleOwnerPrivateNotice)
      : ""
  : "";

// LCP preload: 当文章有 Directus 封面文件且当前对访问者可见时，预加载 WebP 格式
const coverPreloadUrl =
  article?.cover_file && articleVisibleToPublic
    ? buildPublicAssetUrl(article.cover_file, {
        width: 1200,
        height: 675,
        fit: "cover",
        format: "webp",
      })
    : null;

const lastEditedAt = article?.date_updated || article?.date_created || null;
const lastEditedMetaText = formatSiteDateTime(lastEditedAt, siteDateContext);
const createdMetaText = formatSiteDateTime(
  article?.date_created,
  siteDateContext,
);
const articleSharePayload: SharePosterPayload | undefined =
  articleSupportsPublicInteraction && article
    ? {
        title: article.title || i18n(I18nKey.contentUntitled),
        author:
          article.author?.display_name ||
          article.author?.name ||
          defaultSiteSettings.site.title,
        description: article.summary || "",
        pubDate: article.date_created || article.date_updated || "",
        coverImage: coverUrl,
        url: Astro.url.toString(),
        siteTitle:
          Astro.locals.siteSettings?.settings.site.title ||
          defaultSiteSettings.site.title,
        avatar: article.author?.avatar_url || null,
        hiddenUntilDecrypt: Boolean(encryptedBody),
      }
    : undefined;
const hasReadyAiSummary = Boolean(
  article?.summary && article.summary_source === "ai",
);
const hasStaticSummaryCard = Boolean(
  article?.summary &&
  (article.summary_source === "manual" || article.summary_source === "ai"),
);
const shouldRenderAiSummaryCard =
  showPendingAiSummarySkeleton || hasStaticSummaryCard;
const articleAiSummaryInitialStatus =
  articleAiSummaryJobStatus || (hasReadyAiSummary ? "succeeded" : null);
const articleAiSummaryPollUrl = article
  ? `/api/v1/public/articles/${encodeURIComponent(article.id)}?bypass_cache=1`
  : "";
const summaryCardTitle =
  article?.summary_source === "ai"
    ? i18n(I18nKey.interactionArticleAiSummaryTitle)
    : i18n(I18nKey.interactionArticleSummaryTitle);
---

<MainGridLayout
  setOGTypeArticle={true}
  title={article
    ? article.title || i18n(I18nKey.contentUntitled)
    : i18n(I18nKey.contentArticleNotFoundTitle)}
  description={article?.summary || ""}
  leftSidebarMobilePreset="hidden"
  rightSidebarMobilePreset="drawer"
>
  {
    coverPreloadUrl && (
      <link
        slot="head"
        rel="preload"
        as="image"
        type="image/webp"
        href={coverPreloadUrl}
      />
    )
  }
  {
    ogImageUrl && (
      <>
        <meta slot="head" property="og:image" content={ogImageUrl} />
        <meta slot="head" name="twitter:image" content={ogImageUrl} />
      </>
    )
  }
  {
    !article ? (
      <ContentNotVisible
        mode="not_found"
        title={i18n(I18nKey.contentArticleNotFoundTitle)}
        description={i18n(I18nKey.contentArticleNotFoundDescription)}
        backHref="/"
        backLabel={i18n(I18nKey.contentUserBackToHome)}
      />
    ) : (
      <>
        <article
          id="post-container"
          data-enter-skeleton-target="post-detail"
          class="card-base p-6 rounded-(--radius-large) mb-4 relative"
        >
          <div data-enter-skeleton-content>
            <header class="mb-6 space-y-3">
              <h1 class="text-3xl font-bold text-90 font-content-serif">
                {article.title || i18n(I18nKey.contentUntitled)}
              </h1>
              {ownerOnlyNotice && (
                <p class="rounded-xl border border-(--line-divider) bg-(--btn-plain-bg-hover) px-4 py-3 text-sm text-75">
                  {ownerOnlyNotice}
                </p>
              )}
              <div class="flex flex-wrap items-center gap-3 text-sm text-60">
                {article.date_created && createdMetaText && (
                  <span>
                    {i18n(I18nKey.contentArticleCreatedAtLabel)}：
                    <time datetime={article.date_created}>
                      {createdMetaText}
                    </time>
                  </span>
                )}
                {lastEditedAt && lastEditedMetaText && (
                  <span>
                    {i18n(I18nKey.contentArticleLastEditedLabel)}：
                    <time datetime={lastEditedAt}>{lastEditedMetaText}</time>
                  </span>
                )}
                {article.category && (
                  // 分类使用胶囊样式，和时间信息形成明显视觉区分。
                  <span class="inline-flex items-center gap-1.5 rounded-full border border-(--md-sys-color-outline-variant) bg-(--md-sys-color-secondary-container) px-2.5 py-1 text-xs font-semibold text-(--md-sys-color-on-secondary-container)">
                    <span class="text-[0.7rem] opacity-80">
                      {i18n(I18nKey.interactionCommonCategory)}
                    </span>
                    <span class="max-w-[16rem] truncate">
                      {article.category}
                    </span>
                  </span>
                )}
              </div>
              {article.tags.length > 0 && (
                <div class="flex flex-wrap gap-2">
                  {article.tags.map((tag) => (
                    <span class="btn-regular h-7 text-xs px-3 rounded-lg">
                      #{tag}
                    </span>
                  ))}
                </div>
              )}
            </header>

            {coverUrl && (
              <div class="mb-6">
                {hasCoverFile && article?.cover_file ? (
                  <ResponsiveImage
                    fileId={article.cover_file}
                    alt={article.title || i18n(I18nKey.contentUntitled)}
                    preset="cover"
                    eager
                    isPublic={articleVisibleToPublic}
                    class="w-full max-h-[420px] object-cover rounded-xl border border-(--line-divider)"
                  />
                ) : (
                  <ExternalImage
                    src={coverUrl}
                    alt={article.title || i18n(I18nKey.contentUntitled)}
                    class="w-full max-h-[420px] object-cover rounded-xl border border-(--line-divider)"
                    loading="lazy"
                  />
                )}
              </div>
            )}

            {encryptedBody ? (
              <PasswordProtection
                encryptedContent={encryptedBody}
                ownerUserId={article?.author?.id || ""}
                ownerPasswordStorageKeys={ownerPasswordStorageKeys}
              />
            ) : (
              <>
                {shouldRenderAiSummaryCard && (
                  <section
                    class="mb-6"
                    data-ai-summary-root
                    data-ai-summary-article-id={article.id}
                    data-ai-summary-status={articleAiSummaryInitialStatus || ""}
                    data-ai-summary-poll-url={articleAiSummaryPollUrl}
                    data-ai-summary-generating-label={i18n(
                      I18nKey.interactionArticleAiSummaryGenerating,
                    )}
                    data-ai-summary-queued-label={i18n(
                      I18nKey.interactionArticleAiSummaryQueued,
                    )}
                    data-ai-summary-failed-label={i18n(
                      I18nKey.interactionArticleAiSummaryFailed,
                    )}
                    data-ai-summary-generating-hint={i18n(
                      I18nKey.interactionArticleAiSummaryGeneratingHint,
                    )}
                    data-ai-summary-queued-hint={i18n(
                      I18nKey.interactionArticleAiSummaryQueuedHint,
                    )}
                    data-ai-summary-failed-hint={i18n(
                      I18nKey.interactionArticleAiSummaryFailedHint,
                    )}
                  >
                    <aside
                      class:list={[
                        "article-ai-summary-card article-ai-summary-card--pending article-ai-summary-card--marquee rounded-2xl p-[1px]",
                        {
                          hidden: !showPendingAiSummarySkeleton,
                        },
                      ]}
                      data-ai-summary-skeleton-card
                    >
                      <div class="article-ai-summary-panel rounded-[calc(var(--radius-large)-1px)] px-5 py-4">
                        <div class="mb-3 flex items-center justify-between gap-3">
                          <div>
                            <p class="article-ai-summary-title text-xs font-semibold uppercase tracking-[0.18em] mb-1">
                              {i18n(I18nKey.interactionArticleAiSummaryTitle)}
                            </p>
                            <p
                              class="article-ai-summary-hint text-sm"
                              data-ai-summary-hint
                            >
                              {articleAiSummaryJobStatus === "processing"
                                ? i18n(
                                    I18nKey.interactionArticleAiSummaryGeneratingHint,
                                  )
                                : i18n(
                                    I18nKey.interactionArticleAiSummaryQueuedHint,
                                  )}
                            </p>
                          </div>
                          <span
                            class="article-ai-summary-status-pill"
                            data-ai-summary-pill-label
                          >
                            {articleAiSummaryJobStatus === "processing"
                              ? i18n(
                                  I18nKey.interactionArticleAiSummaryGenerating,
                                )
                              : i18n(I18nKey.interactionArticleAiSummaryQueued)}
                          </span>
                        </div>
                        <div
                          class="space-y-2.5"
                          aria-hidden="true"
                          data-ai-summary-skeleton-lines
                        >
                          <div
                            class="article-ai-summary-skeleton-line"
                            style="--ai-summary-line-width: 94%;"
                          />
                          <div
                            class="article-ai-summary-skeleton-line"
                            style="--ai-summary-line-width: 88%;"
                          />
                          <div
                            class="article-ai-summary-skeleton-line"
                            style="--ai-summary-line-width: 92%;"
                          />
                          <div
                            class="article-ai-summary-skeleton-line"
                            style="--ai-summary-line-width: 64%;"
                          />
                        </div>
                      </div>
                    </aside>
                    <aside
                      class:list={[
                        "article-ai-summary-card article-ai-summary-card--ready rounded-2xl p-[1px]",
                        {
                          hidden:
                            !hasStaticSummaryCard ||
                            showPendingAiSummarySkeleton,
                        },
                      ]}
                      data-ai-summary-final-card
                    >
                      <div class="article-ai-summary-panel rounded-[calc(var(--radius-large)-1px)] px-5 py-4">
                        <p class="article-ai-summary-title text-xs font-semibold uppercase tracking-[0.18em] mb-2">
                          {summaryCardTitle}
                        </p>
                        <p
                          class="article-ai-summary-body text-base leading-7"
                          data-ai-summary-final-text
                        >
                          {hasStaticSummaryCard ? article?.summary : ""}
                        </p>
                      </div>
                    </aside>
                  </section>
                )}
                <Markdown class="markdown-content content-serif">
                  <Fragment set:html={articleHtml} />
                </Markdown>
              </>
            )}
          </div>
          <div
            data-enter-skeleton-placeholder
            aria-hidden="true"
            class="absolute inset-0 z-20 pointer-events-none p-6"
          >
            <div class="space-y-4">
              <div
                class="md3-skeleton-text"
                style="--skeleton-width: 62%; --skeleton-height: 2rem;"
              />
              <div
                class="md3-skeleton-text"
                style="--skeleton-width: 48%; --skeleton-height: 0.95rem;"
              />
              <div class="space-y-2 pt-1">
                <div class="md3-skeleton-text" style="--skeleton-width: 92%;" />
                <div class="md3-skeleton-text" style="--skeleton-width: 66%;" />
              </div>
              {coverUrl && (
                <div class="md3-skeleton-block h-[240px] w-full rounded-xl" />
              )}
              <div class="space-y-3 pt-2">
                <div
                  class="md3-skeleton-text"
                  style="--skeleton-width: 100%;"
                />
                <div class="md3-skeleton-text" style="--skeleton-width: 96%;" />
                <div class="md3-skeleton-text" style="--skeleton-width: 94%;" />
                <div class="md3-skeleton-text" style="--skeleton-width: 98%;" />
                <div class="md3-skeleton-text" style="--skeleton-width: 90%;" />
                <div class="md3-skeleton-text" style="--skeleton-width: 84%;" />
                <div class="md3-skeleton-text" style="--skeleton-width: 88%;" />
                <div class="md3-skeleton-text" style="--skeleton-width: 72%;" />
              </div>
            </div>
          </div>
        </article>

        <DetailActionFloat
          contentType="article"
          contentId={article.id}
          authorId={article.author?.id || ""}
          likeCount={articleLikeCount}
          commentCount={articleCommentCount}
          likedByViewer={articleLikedByViewer}
          dockToBackTop={true}
          showLikeAction={articleSupportsPublicInteraction}
          showCommentAction={
            articleSupportsPublicInteraction && article.allow_comments
          }
          sharePayload={articleSharePayload}
          editHref={`/posts/${encodeURIComponent(article.short_id || rawId)}/edit`}
          deleteEndpoint={`/api/v1/me/articles/${encodeURIComponent(article.id)}`}
          adminDeleteEndpoint={`/api/v1/admin/content/articles/${encodeURIComponent(article.id)}`}
          deleteConfirmMessage={i18n(I18nKey.contentArticleDeleteConfirm)}
          adminDeleteConfirmMessage={i18n(
            I18nKey.interactionPostDeleteConfirmAdminArticle,
          )}
          deleteSuccessHref="/"
        />

        <section class="mb-4 lg:hidden">
          <Profile />
        </section>

        <Comment
          module="articles"
          contentId={article.id}
          contentShortId={article.short_id || ""}
          contentAuthorId={article?.author?.id || ""}
          allowComments={
            articleSupportsPublicInteraction && article.allow_comments
          }
        />
      </>
    )
  }
  {
    articleSharePayload && (
      <ArticleShareDialog slot="modal" payload={articleSharePayload} />
    )
  }
  {
    showPendingAiSummarySkeleton && (
      <script>import "@/scripts/article-detail/ai-summary-card";</script>
    )
  }
  {
    articleSharePayload && (
      <script>import "@/scripts/interactions/article-share-dialog";</script>
    )
  }
</MainGridLayout>

<style>
  .article-ai-summary-card {
    --article-ai-summary-rainbow: conic-gradient(
      from 0turn,
      #ff4d6d 0%,
      #ff9f1c 16%,
      #ffe66d 32%,
      #2ec4b6 48%,
      #3a86ff 64%,
      #8338ec 80%,
      #ff4d6d 100%
    );
    --article-ai-summary-border: color-mix(
      in srgb,
      var(--primary) 58%,
      var(--line-divider) 42%
    );
    --article-ai-summary-surface: color-mix(
      in srgb,
      var(--card-bg) 94%,
      var(--primary) 6%
    );
    --article-ai-summary-title-color: rgba(0, 0, 0, 0.6);
    --article-ai-summary-body-color: rgba(0, 0, 0, 0.88);
    position: relative;
    overflow: hidden;
    background: var(--article-ai-summary-border);
    box-shadow: 0 12px 28px rgba(15, 23, 42, 0.08);
  }

  .article-ai-summary-panel {
    position: relative;
    z-index: 1;
    background: var(--article-ai-summary-surface);
  }

  .article-ai-summary-title {
    color: var(--article-ai-summary-title-color);
  }

  .article-ai-summary-hint,
  .article-ai-summary-body {
    color: var(--article-ai-summary-body-color);
  }

  .article-ai-summary-body {
    white-space: pre-line;
  }

  .article-ai-summary-skeleton-line {
    width: var(--ai-summary-line-width, 100%);
    height: 0.9rem;
    border-radius: 999px;
    position: relative;
    overflow: hidden;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--primary) 18%, var(--card-bg) 82%),
      color-mix(in srgb, var(--line-divider) 22%, var(--card-bg) 78%)
    );
  }

  .article-ai-summary-skeleton-line::after {
    content: "";
    position: absolute;
    inset: 0;
    width: 58%;
    background: linear-gradient(
      90deg,
      transparent,
      color-mix(in srgb, white 36%, var(--primary) 18%),
      transparent
    );
    transform: translateX(-120%);
    animation: article-ai-summary-shimmer 3.4s ease-in-out infinite;
  }

  .article-ai-summary-status-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border-radius: 999px;
    border: 1px solid
      color-mix(in srgb, var(--primary) 28%, var(--line-divider) 72%);
    padding: 0.35rem 0.7rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
