---
import { Icon } from "astro-icon/components";

import Calendar from "@components/widget/Calendar.astro";
import PostPage from "@components/PostPage.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import {
  getPublicArticleListData,
  getPublicArticleTaxonomyData,
  parsePublicArticleListInput,
  UNCATEGORIZED_ARTICLE_CATEGORY,
} from "@/server/application/public/articles.service";
import type { HomeFeedPageItem } from "@/server/recommendation/home-feed.types";
import {
  buildPageNumbers,
  POSTS_PER_PAGE,
} from "@/scripts/articles/list-filter-helpers";

export const prerender = false;

const articleListInput = parsePublicArticleListInput(Astro.url, {
  defaultLimit: POSTS_PER_PAGE,
  maxLimit: POSTS_PER_PAGE,
});
const uncategorizedLabel = i18n(I18nKey.contentUncategorized);

const [{ items, page, limit, total }, taxonomy] = await Promise.all([
  getPublicArticleListData(articleListInput),
  getPublicArticleTaxonomyData(),
]);

const articleListFeedItems: HomeFeedPageItem[] = items.map((entry) => ({
  type: "article",
  id: entry.data.article_id,
  authorId: entry.data.author_id,
  publishedAt: entry.data.published,
  entry,
  viewerState: {
    hasLiked: false,
    canDeleteOwn: false,
    canDeleteAdmin: false,
  },
}));

const totalPages = Math.max(1, Math.ceil(total / limit));
const pageNumbers = totalPages > 1 ? buildPageNumbers(page, totalPages) : [];
const activeTags = new Set(articleListInput.tags || []);
const activeCategory = articleListInput.category || null;
const hasActiveFilters =
  activeTags.size > 0 ||
  activeCategory !== null ||
  Boolean(articleListInput.authorHandle) ||
  Boolean(articleListInput.q);
const filterSegments: string[] = [];

if (activeTags.size > 0) {
  filterSegments.push(`标签：${Array.from(activeTags).join("、")}`);
}
if (activeCategory) {
  filterSegments.push(
    activeCategory === UNCATEGORIZED_ARTICLE_CATEGORY
      ? `分类：${uncategorizedLabel}`
      : `分类：${activeCategory}`,
  );
}
if (articleListInput.authorHandle) {
  filterSegments.push(`作者：@${articleListInput.authorHandle}`);
}
if (articleListInput.q) {
  filterSegments.push(`搜索：${articleListInput.q}`);
}

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=300, stale-while-revalidate=900",
);
---

<MainGridLayout
  title={i18n(I18nKey.contentPostList)}
  leftSidebarMobilePreset="supplementary"
  rightSidebarMobilePreset="drawer"
  pageKind="article-list"
>
  <div
    class="article-list-page min-w-0 mb-4 lg:mb-0"
    data-page-kind="article-list"
    data-uncategorized-label={uncategorizedLabel}
    data-current-page={String(page)}
    data-total-pages={String(totalPages)}
  >
    {
      articleListFeedItems.length === 0 ? (
        <div class="card-base p-8 rounded-(--radius-large) text-70">
          {hasActiveFilters ? "没有匹配的文章。" : "暂无公开文章。"}
        </div>
      ) : (
        <PostPage items={articleListFeedItems} maxAnimationIndex={15} />
      )
    }

    <div
      id="article-list-no-results"
      class:list={[
        "card-base p-8 rounded-(--radius-large) text-70 mt-4",
        {
          hidden: articleListFeedItems.length > 0 || !hasActiveFilters,
        },
      ]}
    >
      没有匹配的文章。
    </div>

    {
      totalPages > 1 && (
        <div id="article-list-pagination" class="mt-4">
          <div class="card-base p-3 rounded-(--radius-large) flex items-center justify-center gap-2">
            <button
              id="page-prev"
              type="button"
              class:list={[
                "pagination-btn px-3.5 py-2.5",
                {
                  disabled: page <= 1,
                },
              ]}
              aria-label="上一页"
            >
              <Icon
                name="material-symbols:chevron-left-rounded"
                class="text-2xl"
              />
            </button>
            <div id="page-numbers" class="flex items-center gap-1">
              {pageNumbers.map((pageNumber) =>
                pageNumber === -1 ? (
                  <span class="px-1 text-50">...</span>
                ) : pageNumber === page ? (
                  <span class="page-num active">{pageNumber}</span>
                ) : (
                  <button class="page-num" data-page={String(pageNumber)}>
                    {pageNumber}
                  </button>
                ),
              )}
            </div>
            <button
              id="page-next"
              type="button"
              class:list={[
                "pagination-btn px-3.5 py-2.5",
                {
                  disabled: page >= totalPages,
                },
              ]}
              aria-label="下一页"
            >
              <Icon
                name="material-symbols:chevron-right-rounded"
                class="text-2xl"
              />
            </button>
          </div>
        </div>
      )
    }
  </div>

  <div
    slot="sidebar-right"
    class="article-list-filter-panel w-full max-h-none overflow-visible flex flex-col gap-4 self-start lg:max-h-[calc(100dvh-6.5rem)] lg:overflow-y-auto"
  >
    <Calendar defaultExpanded={false} />

    <div class="card-base rounded-(--radius-large) pb-4">
      <div
        class="font-bold transition text-lg text-neutral-900 dark:text-neutral-100 relative ml-8 mt-4 mb-2 flex items-center
          before:w-1 before:h-4 before:rounded-md before:bg-(--primary)
          before:absolute before:left-[-16px] before:top-[5.5px]"
      >
        {i18n(I18nKey.contentCategories)}
      </div>
      <div class="px-4 flex flex-col gap-0.5" id="article-list-categories">
        {
          taxonomy.categories.map((category) => {
            const isActiveCategory = activeCategory === category.name;
            const displayName =
              category.name === UNCATEGORIZED_ARTICLE_CATEGORY
                ? uncategorizedLabel
                : category.name.trim();

            return (
              <button
                data-filter="category"
                data-value={category.name}
                class:list={[
                  "article-list-filter-btn w-full h-10 rounded-lg bg-none hover:bg-(--btn-plain-bg-hover) active:bg-(--btn-plain-bg-active) transition-all pl-2 hover:pl-3 text-left text-neutral-700 hover:text-(--primary) dark:text-neutral-300 dark:hover:text-(--primary) cursor-pointer",
                  {
                    active: isActiveCategory,
                  },
                ]}
              >
                <div class="flex items-center justify-between mr-2">
                  <span class="overflow-hidden whitespace-nowrap text-ellipsis">
                    {displayName}
                  </span>
                  <span
                    class="transition px-2 h-7 ml-4 min-w-[2rem] rounded-lg text-sm font-bold
                      text-(--btn-content) dark:text-(--deep-text)
                      bg-[oklch(0.95_0.025_var(--hue))] dark:bg-(--primary)
                      flex items-center justify-center shrink-0"
                  >
                    {category.count}
                  </span>
                </div>
              </button>
            );
          })
        }
      </div>
    </div>

    <div class="card-base rounded-(--radius-large) pb-4">
      <div
        class="font-bold transition text-lg text-neutral-900 dark:text-neutral-100 relative ml-8 mt-4 mb-2 flex items-center
          before:w-1 before:h-4 before:rounded-md before:bg-(--primary)
          before:absolute before:left-[-16px] before:top-[5.5px]"
      >
        {i18n(I18nKey.contentTags)}
      </div>
      <div class="px-4 flex gap-2 flex-wrap" id="article-list-tags">
        {
          taxonomy.tags.map((tag) => (
            <button
              data-filter="tag"
              data-value={tag.name}
              class:list={[
                "article-list-filter-btn btn-regular h-8 text-sm px-3 rounded-lg cursor-pointer",
                {
                  active: activeTags.has(tag.name),
                },
              ]}
            >
              {tag.name.trim()}
            </button>
          ))
        }
      </div>
    </div>

    <div
      id="filter-status"
      class:list={[
        "card-base rounded-(--radius-large) px-4 py-3",
        {
          "is-collapsed": !hasActiveFilters,
        },
      ]}
    >
      <span id="filter-status-label" class="text-sm text-75 truncate">
        {filterSegments.join(" ｜ ")}
      </span>
      <button
        id="filter-clear-btn"
        class="shrink-0 text-sm text-(--primary) hover:underline cursor-pointer"
      >
        清除
      </button>
    </div>
  </div>
</MainGridLayout>

<style>
  @reference "../../styles/main.css";

  .article-list-filter-panel::-webkit-scrollbar {
    width: 4px;
  }
  .article-list-filter-panel::-webkit-scrollbar-track {
    background: transparent;
  }
  .article-list-filter-panel::-webkit-scrollbar-thumb {
    background-color: rgba(156, 163, 175, 0.3);
    border-radius: 2px;
  }

  :global(.article-list-filter-btn.active) {
    background-color: var(--primary) !important;
    color: white !important;
  }

  #filter-status.is-collapsed {
    display: none;
  }

  #filter-status:not(.is-collapsed) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  :global(.article-list-filter-btn.active .flex span:last-child) {
    background-color: rgba(255, 255, 255, 0.2) !important;
    color: white !important;
  }

  :global(.pagination-btn) {
    @apply px-3 py-2 rounded-lg text-sm font-bold
      text-neutral-600 dark:text-neutral-400
      hover:bg-(--btn-plain-bg-hover)
      hover:text-(--primary)
      transition-colors cursor-pointer;
  }
  :global(.pagination-btn.disabled) {
    @apply opacity-40 pointer-events-none;
  }
  :global(.page-num) {
    @apply w-9 h-9 rounded-lg text-sm font-bold
      flex items-center justify-center cursor-pointer
      transition-colors
      text-neutral-700 dark:text-neutral-300
      hover:bg-(--btn-plain-bg-hover);
  }
  :global(.page-num.active) {
    @apply bg-(--primary) text-white;
  }
</style>
