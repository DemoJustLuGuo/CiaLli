---
import OwnerOnlyGate from "@components/auth/OwnerOnlyGate.astro";
import ContentNotVisible from "@components/misc/ContentNotVisible.astro";
import AlbumCardCompact from "@components/home/AlbumCardCompact.astro";
import ArticleCardCompact from "@components/home/ArticleCardCompact.astro";
import BangumiCardCompact from "@components/home/BangumiCardCompact.astro";
import DiaryCardCompact from "@components/home/DiaryCardCompact.astro";
import HorizontalScrollSection from "@components/home/HorizontalScrollSection.astro";
import ExternalImage from "@components/misc/ExternalImage.astro";
import ImageWrapper from "@components/misc/ImageWrapper.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import {
  loadPublicProfileByUsername,
  loadUserHomeData,
  profileToSidebarData,
} from "@/server/api/v1/public-data";
import type {
  ContentLoadResult,
  UserHomeData,
} from "@/server/api/v1/public-data";
import { isSpecialArticleSlug } from "@/server/api/v1/shared/helpers";
import {
  loadPublicArticleByShortId,
  loadPublicArticleBySlug,
} from "@/server/api/v1/shared/loaders";
import { runWithDirectusPublicAccess } from "@/server/directus/client";
import { getResolvedSiteSettings } from "@/server/site-settings/service";
import { isShortId } from "@/server/utils/short-id";
import { resolveDisplayAvatarUrl } from "@/utils/profile-avatar";

const USER_PUBLIC_PAGE_CACHE_CONTROL =
  "public, s-maxage=60, stale-while-revalidate=300";

const username = (Astro.params.username || "").trim();

let result: ContentLoadResult<UserHomeData> = { status: "not_found" };

try {
  if (!username) {
    Astro.response.status = 404;
  } else {
    result = await runWithDirectusPublicAccess(
      async () => await loadUserHomeData(username),
    );
    if (result.status === "not_found") {
      // 用户不存在，尝试作为文章短链接解析
      const article = await runWithDirectusPublicAccess(async () =>
        isShortId(username)
          ? await loadPublicArticleByShortId(username)
          : isSpecialArticleSlug(username)
            ? await loadPublicArticleBySlug(username)
            : null,
      );
      if (article?.short_id) {
        return Astro.redirect(`/posts/${article.short_id}`, 302);
      }
      Astro.response.status = 404;
    } else if (result.status === "permission_denied") {
      Astro.response.status = 404;
    } else {
      const sidebarProfile = await runWithDirectusPublicAccess(
        async () => await loadPublicProfileByUsername(username),
      );
      if (sidebarProfile) {
        // 个人主页侧栏优先显示当前主页用户资料，避免回退到官方账户
        Astro.locals.sidebarProfile = profileToSidebarData(sidebarProfile);
      }
      Astro.response.headers.set(
        "Cache-Control",
        USER_PUBLIC_PAGE_CACHE_CONTROL,
      );
    }
  }
} catch (error) {
  console.error("[profile] failed to load user home:", error);
  Astro.response.status = 500;
}

const payload = result.status === "ok" ? result.data : null;
const ownerUsername = payload?.owner?.username || username;
const resolvedSiteSettings =
  Astro.locals.siteSettings ?? (await getResolvedSiteSettings());
// 主页头像与侧栏 Profile 统一回退到站点默认头像，避免无头像用户出现空占位。
const profileCardAvatarUrl = resolveDisplayAvatarUrl(
  payload?.owner?.avatar_url,
  resolvedSiteSettings.settings.profile.avatar,
);

const DEFAULT_SECTION_ORDER = ["articles", "diaries", "bangumi", "albums"];
const sectionOrder =
  payload?.profile?.home_section_order ?? DEFAULT_SECTION_ORDER;
---

<MainGridLayout
  title={payload?.owner?.name || i18n(I18nKey.contentUserProfileTitle)}
  description={payload?.profile?.bio || ""}
  leftSidebarMobilePreset="supplementary-without-announcement"
>
  {
    result.status === "not_found" || result.status === "permission_denied" ? (
      <ContentNotVisible
        mode="not_found"
        title={i18n(I18nKey.contentUserNotFoundTitle)}
        description={i18n(I18nKey.contentUserNotFoundDescription)}
        backHref="/"
        backLabel={i18n(I18nKey.contentUserBackToHome)}
      />
    ) : (
      <>
        <OwnerOnlyGate />
        <div
          data-enter-skeleton-page="user-home"
          data-enter-skeleton-target="user-home"
        >
          <div data-enter-skeleton-inline-content>
            {/* ── 用户卡片区域（含头图） ── */}
            <section class="card-base rounded-(--radius-large) mb-4 overflow-hidden relative">
              <a
                href="/me/homepage"
                class="absolute top-3 right-3 z-10 flex items-center justify-center w-11 h-11 rounded-full bg-black/35 hover:bg-black/55 text-white transition-colors backdrop-blur-sm sm:top-4 sm:right-4"
                aria-label={i18n(I18nKey.interactionCommonEdit)}
                title={i18n(I18nKey.interactionCommonEdit)}
                data-owner-only
                data-owner-id={payload?.owner?.id ?? ""}
                hidden
                aria-hidden="true"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-4 h-4"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M17 3a2.85 2.83 0 114 4L7.5 20.5 2 22l1.5-5.5Z" />
                  <path d="m15 5 4 4" />
                </svg>
              </a>
              {payload!.owner?.header_url ? (
                <div class="relative h-40 sm:h-52 md:h-66">
                  <ExternalImage
                    src={payload!.owner.header_url}
                    alt="header image"
                    class="w-full h-full object-cover"
                    loading="eager"
                  />
                  <div class="absolute inset-x-0 bottom-0 h-16 bg-linear-to-t from-(--card-bg) to-transparent sm:h-24" />
                </div>
              ) : (
                <div class="h-24 bg-linear-to-br from-black/8 to-black/3 dark:from-white/8 dark:to-white/3 sm:h-32" />
              )}

              <div class="px-4 pb-5 -mt-8 relative sm:px-6 sm:pb-6 sm:-mt-10">
                <div class="flex flex-col items-start gap-3 sm:flex-row sm:items-end sm:gap-4">
                  {profileCardAvatarUrl ? (
                    <div class="w-[4.5rem] h-[4.5rem] rounded-full border-3 border-(--card-bg) shadow-sm overflow-hidden shrink-0 sm:w-20 sm:h-20">
                      <ImageWrapper
                        src={profileCardAvatarUrl}
                        alt="avatar"
                        class="w-full h-full rounded-full"
                        loading="eager"
                      />
                    </div>
                  ) : (
                    <div class="w-[4.5rem] h-[4.5rem] rounded-full bg-black/10 dark:bg-white/10 border-2 border-(--card-bg) shrink-0 sm:w-20 sm:h-20" />
                  )}
                  <div class="min-w-0 flex-1 space-y-1 sm:pb-1">
                    <h1 class="text-xl font-bold leading-tight text-90 break-words sm:text-2xl">
                      {payload!.owner?.name ||
                        i18n(I18nKey.contentUserProfileDefaultName)}
                    </h1>
                    <p class="text-xs text-60 break-all sm:text-sm">
                      {"@"}
                      {ownerUsername}
                    </p>
                  </div>
                </div>
                {payload!.profile?.bio && (
                  <p class="mt-3 text-sm text-75 leading-6 break-words sm:mt-4 sm:leading-7">
                    {payload!.profile.bio}
                  </p>
                )}
              </div>
            </section>

            {/* ── 动态排序内容模块 ── */}
            {sectionOrder.map((section: string) => {
              if (
                section === "articles" &&
                Array.isArray(payload!.articles) &&
                payload!.articles.length > 0
              ) {
                return (
                  <HorizontalScrollSection
                    title={i18n(I18nKey.contentPostList)}
                    moreHref={`/posts?author=${ownerUsername}`}
                  >
                    {payload!.articles.map((item) => (
                      <ArticleCardCompact
                        article={item}
                        username={ownerUsername}
                      />
                    ))}
                  </HorizontalScrollSection>
                );
              }
              if (
                section === "diaries" &&
                Array.isArray(payload!.diaries) &&
                payload!.diaries.length > 0
              ) {
                return (
                  <HorizontalScrollSection
                    title={i18n(I18nKey.contentDiary)}
                    moreHref={`/${ownerUsername}/diary`}
                  >
                    {payload!.diaries.map((item) => (
                      <DiaryCardCompact diary={item} username={ownerUsername} />
                    ))}
                  </HorizontalScrollSection>
                );
              }
              if (
                section === "bangumi" &&
                Array.isArray(payload!.bangumi) &&
                payload!.bangumi.length > 0
              ) {
                return (
                  <HorizontalScrollSection
                    title={i18n(I18nKey.contentAnime)}
                    moreHref={`/${ownerUsername}/bangumi`}
                  >
                    {payload!.bangumi.map((item) => (
                      <BangumiCardCompact bangumi={item} />
                    ))}
                  </HorizontalScrollSection>
                );
              }
              if (
                section === "albums" &&
                Array.isArray(payload!.albums) &&
                payload!.albums.length > 0
              ) {
                return (
                  <HorizontalScrollSection
                    title={i18n(I18nKey.contentAlbums)}
                    moreHref={`/${ownerUsername}/albums?author=${ownerUsername}`}
                  >
                    {payload!.albums.map((item) => (
                      <AlbumCardCompact album={item} username={ownerUsername} />
                    ))}
                  </HorizontalScrollSection>
                );
              }
              return null;
            })}
          </div>

          {/* ── 骨架屏 ── */}
          <div
            data-enter-skeleton-inline-placeholder
            aria-hidden="true"
            class="space-y-4"
          >
            {/* 头图区域骨架 */}
            <section class="card-base rounded-(--radius-large) overflow-hidden">
              <div class="md3-skeleton-block h-40 w-full sm:h-66" />
              <div class="px-4 pb-5 -mt-8 relative sm:px-6 sm:pb-6 sm:-mt-10">
                <div class="flex flex-col items-start gap-3 sm:flex-row sm:items-end sm:gap-4">
                  <div class="md3-skeleton-circle w-20 h-20 border-2 border-(--card-bg)" />
                  <div class="flex-1 space-y-2 pb-1">
                    <div
                      class="md3-skeleton-text"
                      style="--skeleton-width: 34%; --skeleton-height: 1.6rem;"
                    />
                    <div
                      class="md3-skeleton-text"
                      style="--skeleton-width: 20%; --skeleton-height: 0.78rem;"
                    />
                  </div>
                </div>
                <div class="space-y-2 pt-4">
                  <div
                    class="md3-skeleton-text"
                    style="--skeleton-width: 90%;"
                  />
                  <div
                    class="md3-skeleton-text"
                    style="--skeleton-width: 70%;"
                  />
                </div>
              </div>
            </section>

            {/* 横向滚动骨架 ×4 */}
            {Array.from({ length: 4 }).map(() => (
              <section class="card-base rounded-(--radius-large) overflow-hidden p-6 space-y-3">
                <div
                  class="md3-skeleton-text"
                  style="--skeleton-width: 18%; --skeleton-height: 1.2rem;"
                />
                <div class="flex gap-4 overflow-hidden">
                  {Array.from({ length: 3 }).map(() => (
                    <div class="shrink-0 w-[240px] rounded-xl overflow-hidden">
                      <div class="md3-skeleton-block h-36 w-full" />
                      <div class="p-3 space-y-2">
                        <div
                          class="md3-skeleton-text"
                          style="--skeleton-width: 80%; --skeleton-height: 0.9rem;"
                        />
                        <div
                          class="md3-skeleton-text"
                          style="--skeleton-width: 50%; --skeleton-height: 0.7rem;"
                        />
                      </div>
                    </div>
                  ))}
                </div>
              </section>
            ))}
          </div>
        </div>
      </>
    )
  }
</MainGridLayout>
