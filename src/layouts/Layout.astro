---
import { ClientRouter } from "astro:transitions";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import ConfigCarrier from "@components/ConfigCarrier.astro";
import MusicPlayer from "@components/widget/MusicPlayer/MusicPlayer.svelte";
import { buildLegacySiteConfig } from "@/config";
import { getResolvedSiteSettings } from "@/server/site-settings/service";
import { readCsrfToken } from "@/server/security/csrf";
import type { ResolvedSiteSettings } from "@/types/site-settings";

const BANNER_HEIGHT = 35;
const BANNER_HEIGHT_EXTEND = 30;
const BANNER_HEIGHT_HOME = BANNER_HEIGHT + BANNER_HEIGHT_EXTEND;
const PAGE_SCALE_MIN_WIDTH = 1280;

import {
  DARK_MODE,
  DEFAULT_THEME,
  LIGHT_MODE,
  PAGE_WIDTH,
} from "../constants/constants";
import { defaultFavicons } from "@constants/icon";
import type { Favicon } from "@/types/config";
import { pathsEqual, url } from "@utils/url-utils";
import "../styles/wallpaper-navbar-transparent.css";
import "../styles/fancybox-custom.css";
import "../styles/expressive-code.css";
import "../styles/panel-animations.css";
import "../styles/skeleton.css";
import "../styles/variables.styl";
import "../styles/main.css";

interface Props {
  title?: string;
  banner?: string;
  description?: string;
  lang?: string;
  setOGTypeArticle?: boolean;
}

const resolvedSiteSettings: ResolvedSiteSettings =
  Astro.locals.siteSettings ?? (await getResolvedSiteSettings());
const siteConfig = buildLegacySiteConfig(
  resolvedSiteSettings.system,
  resolvedSiteSettings.settings,
);
const profileName = resolvedSiteSettings.settings.profile.name;
const musicPlayerSettings = resolvedSiteSettings.settings.musicPlayer;
const analyticsConfig = {
  gtmId: String(resolvedSiteSettings.settings.analytics.gtmId || "").trim(),
  clarityId: String(
    resolvedSiteSettings.settings.analytics.clarityId || "",
  ).trim(),
};
const csrfTokenFromLocals =
  typeof Astro.locals.csrfToken === "string" ? Astro.locals.csrfToken : "";
const csrfToken = csrfTokenFromLocals || readCsrfToken(Astro);

// 在首屏渲染时先为 body 打上类名，用于决定 banner 高度
// 虽然 View Transitions 会在切页后更新 body，但时机在动画之后，会造成高度切换延迟
// 因此仍需在点击链接时通过 transition hooks 立即切换布局态
const isHomePage = pathsEqual(Astro.url.pathname, url("/"));
const normalizedPathname = Astro.url.pathname.replace(/\/+$/, "").toLowerCase();
const isArchivePage =
  normalizedPathname === "/posts" || normalizedPathname.endsWith("/posts");
const isPostEditorRoute =
  normalizedPathname === "/posts/new" ||
  /^\/posts\/[^/]+\/edit$/.test(normalizedPathname);

// 定义全局 CSS 变量
// 放在 Layout 而非 GlobalStyles 的原因见：
// https://github.com/withastro/astro/issues/6728#issuecomment-1502203757
const configHue = siteConfig.themeColor.hue;

let { title, description, lang, setOGTypeArticle } = Astro.props;

const enableBanner = !!siteConfig.banner.src;
const initialLayoutMode =
  enableBanner &&
  isHomePage &&
  siteConfig.wallpaperMode.defaultMode === "banner"
    ? "banner"
    : "none";

let pageTitle: string;
if (title) {
  pageTitle = `${title} - ${siteConfig.title}`;
} else {
  pageTitle = siteConfig.subtitle
    ? `${siteConfig.title} - ${siteConfig.subtitle}`
    : siteConfig.title;
}

const favicons: Favicon[] =
  siteConfig.favicon.length > 0 ? siteConfig.favicon : defaultFavicons;

const resolveFaviconHref = (src: string): string => {
  const value = String(src || "").trim();
  if (!value) {
    return "";
  }
  if (value.startsWith("/")) {
    return url(value);
  }
  if (value.startsWith("assets/")) {
    return url(`/${value}`);
  }
  return value;
};

// const siteLang = siteConfig.lang.replace('_', '-') // 预留：历史写法
if (!lang) {
  lang = `${siteConfig.lang}`;
}
const siteLang = lang.replace("_", "-");

const bannerOffsetByPosition = {
  top: `${BANNER_HEIGHT_EXTEND}vh`,
  center: `${BANNER_HEIGHT_EXTEND / 2}vh`,
  bottom: "0",
};
const bannerOffset =
  bannerOffsetByPosition[siteConfig.banner.position || "center"];
const pageWidthRem = `${PAGE_WIDTH}rem`;
const bannerHeightHomeVh = `${BANNER_HEIGHT_HOME}vh`;
const bannerHeightVh = `${BANNER_HEIGHT}vh`;

const gtmId = analyticsConfig.gtmId;
const clarityId = analyticsConfig.clarityId;
const analyticsEnabled = Boolean(gtmId || clarityId);
const htmlClassName = [
  "bg-(--page-bg)",
  isPostEditorRoute ? "route-post-editor" : "",
]
  .filter(Boolean)
  .join(" ");
const bodyClassName = [
  "min-h-screen",
  isArchivePage ? "page-archive" : "",
  isPostEditorRoute ? "route-post-editor" : "",
  initialLayoutMode === "banner" ? "enable-banner" : "no-banner-mode",
  initialLayoutMode !== "banner" ? "waves-paused" : "",
]
  .filter(Boolean)
  .join(" ");
---

<!doctype html>
<html
  lang={siteLang}
  class={htmlClassName}
  style={`--page-width:${pageWidthRem};--hue:${configHue};`}
  data-overlayscrollbars-initialize
>
  <head>
    <ClientRouter fallback="swap" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:wght@400;500;600;700&family=Long+Cang&family=Noto+Sans+JP:wght@400;500;700&family=Noto+Sans+Mono:wght@400;500;700&family=Noto+Sans+SC:wght@400;500;700&family=Noto+Serif+SC:wght@400;500;600;700&family=Noto+Serif+TC:wght@400;500;600;700&display=swap"
    />

    <script is:inline>
      (() => {
        if (typeof window === "undefined" || typeof Node === "undefined") {
          return;
        }

        const resolveInheritedGetter = (proto, key) => {
          let cursor = Object.getPrototypeOf(proto);
          while (cursor) {
            const descriptor = Object.getOwnPropertyDescriptor(cursor, key);
            if (typeof descriptor?.get === "function") {
              return descriptor.get;
            }
            cursor = Object.getPrototypeOf(cursor);
          }
          return null;
        };

        const patchGetter = (key, fallbackGetter) => {
          const descriptor = Object.getOwnPropertyDescriptor(
            Node.prototype,
            key,
          );
          if (typeof descriptor?.get === "function") {
            return;
          }

          const inheritedGetter = resolveInheritedGetter(Node.prototype, key);
          const getter = inheritedGetter || fallbackGetter;

          try {
            Object.defineProperty(Node.prototype, key, {
              configurable: true,
              enumerable: descriptor?.enumerable ?? false,
              get() {
                return getter(this);
              },
            });
          } catch (error) {
            console.warn(`[layout] 修复 Node.${key} 访问器失败:`, error);
          }
        };

        patchGetter("firstChild", (node) => node.childNodes?.item(0) || null);
        patchGetter("nextSibling", (node) => {
          const parent = node.parentNode;
          if (!parent) {
            return null;
          }
          const siblings = parent.childNodes;
          const currentIndex = Array.prototype.indexOf.call(siblings, node);
          if (currentIndex < 0) {
            return null;
          }
          return siblings.item(currentIndex + 1) || null;
        });
      })();
    </script>
    <script is:inline define:vars={{ gtmId, clarityId, analyticsEnabled }}>
      if (analyticsEnabled) {
        // 使用 requestIdleCallback 延迟加载第三方脚本
        const loadAnalytics = () => {
          // Google Tag Manager 脚本
          if (gtmId) {
            (function (w, d, s, l, i) {
              w[l] = w[l] || [];
              w[l].push({
                "gtm.start": new Date().getTime(),
                event: "gtm.js",
              });
              const f = d.getElementsByTagName(s)[0];
              const j = d.createElement(s);
              const dl = l !== "dataLayer" ? "&l=" + l : "";
              j.async = true;
              j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
              f.parentNode.insertBefore(j, f);
            })(window, document, "script", "dataLayer", gtmId);
          }

          // Clarity 脚本
          if (clarityId) {
            (function (c, l, a, r, i, t, y) {
              c[a] =
                c[a] ||
                function () {
                  (c[a].q = c[a].q || []).push(arguments);
                };
              t = l.createElement(r);
              t.async = true;
              t.src = "https://www.clarity.ms/tag/" + i;
              y = l.getElementsByTagName(r)[0];
              y.parentNode.insertBefore(t, y);
            })(window, document, "clarity", "script", clarityId);
          }
        };

        // 浏览器空闲时加载；若长期不空闲则 3 秒后兜底加载
        if ("requestIdleCallback" in window) {
          requestIdleCallback(loadAnalytics, { timeout: 3000 });
        } else {
          setTimeout(loadAnalytics, 3000);
        }
      }
    </script>

    <title>{pageTitle}</title>
    <meta charset="UTF-8" />
    <meta name="description" content={description || pageTitle} />
    {
      siteConfig.keywords && siteConfig.keywords.length > 0 && (
        <meta name="keywords" content={siteConfig.keywords.join(", ")} />
      )
    }
    <meta name="author" content={profileName} />
    <meta property="og:site_name" content={siteConfig.title} />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description || pageTitle} />
    {
      setOGTypeArticle ? (
        <meta property="og:type" content="article" />
      ) : (
        <meta property="og:type" content="website" />
      )
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description || pageTitle} />
    <meta name="viewport" content="width=device-width" />
    <meta name="cialli-csrf-token" content={csrfToken} />
    <script is:inline>
      (function bootstrapCsrfToken() {
        const meta = document.querySelector('meta[name="cialli-csrf-token"]');
        if (!(meta instanceof HTMLMetaElement) || meta.content) {
          return;
        }
        void fetch("/api/auth/csrf", {
          method: "GET",
          credentials: "include",
          headers: {
            Accept: "application/json",
          },
        })
          .then((response) =>
            response.ok ? response.json().catch(() => null) : null,
          )
          .then((data) => {
            const token =
              data && data.ok && typeof data.token === "string"
                ? data.token
                : "";
            if (token) {
              meta.content = token;
            }
          })
          .catch(() => null);
      })();
    </script>
    <meta name="generator" content={Astro.generator} />
    {
      favicons.map((favicon) => (
        <link
          rel="icon"
          href={resolveFaviconHref(favicon.src)}
          sizes={favicon.sizes}
          media={favicon.theme && `(prefers-color-scheme: ${favicon.theme})`}
        />
      ))
    }

    <!-- 在页面渲染前先设置主题，避免闪烁 -->
    <script
      is:inline
      define:vars={{
        DEFAULT_THEME,
        LIGHT_MODE,
        DARK_MODE,
        BANNER_HEIGHT_EXTEND,
        PAGE_WIDTH,
        PAGE_SCALE_MIN_WIDTH,
        configHue,
        pageScaling: siteConfig.pageScaling,
      }}
    >
      // 从本地存储读取主题
      const theme = localStorage.getItem("theme") || DEFAULT_THEME;
      let isDark = false;
      switch (theme) {
        case LIGHT_MODE:
          document.documentElement.classList.remove("dark");
          isDark = false;
          break;
        case DARK_MODE:
          document.documentElement.classList.add("dark");
          isDark = true;
          break;
      }

      // 按当前主题模式同步 Expressive Code 主题
      const expressiveTheme = isDark ? "github-dark" : "github-light";
      const currentTheme = document.documentElement.getAttribute("data-theme");
      // 只在主题不同时才更新，避免触发不必要的重绘
      if (currentTheme !== expressiveTheme) {
        document.documentElement.setAttribute("data-theme", expressiveTheme);
      }

      // 主题色相改为固定配置，移除本地覆盖分支。
      document.documentElement.style.setProperty("--hue", configHue);

      // 计算 --banner-height-extend，取 4 的倍数以避免文字发虚
      let offset = Math.floor(
        window.innerHeight * (BANNER_HEIGHT_EXTEND / 100),
      );
      offset = offset - (offset % 4);
      document.documentElement.style.setProperty(
        "--banner-height-extend",
        `${offset}px`,
      );

      // 自动缩放逻辑（从 MainGridLayout 前移，尽早执行）
      (function () {
        const targetWidth = Number(pageScaling?.targetWidth || 0);
        if (!Number.isFinite(targetWidth) || targetWidth <= 0) {
          return;
        }

        function adjustPageScale() {
          const currentWidth = document.documentElement.clientWidth;
          // 仅在宽屏下启用整体缩放，避免影响移动端与平板端的原生响应式布局。
          if (currentWidth < PAGE_SCALE_MIN_WIDTH) {
            document.documentElement.style.fontSize = "";
            return;
          }
          let scale = currentWidth / targetWidth;
          if (scale > 1) scale = 1;
          if (scale < 0.85) scale = 0.85;
          document.documentElement.style.fontSize = `${scale * 100}%`;
        }

        // 立即执行一次
        adjustPageScale();

        // 监听窗口尺寸变化
        window.addEventListener("resize", adjustPageScale);

        // 页面切换后也需要检查
        document.addEventListener("astro:page-load", adjustPageScale);
      })();
    </script>
    <!-- 定义全局 CSS 变量，会作用到 <html>、<body> 及部分根节点 -->
    <slot name="head" />

    <link
      rel="alternate"
      type="application/rss+xml"
      title={profileName}
      href={`${Astro.site}rss.xml`}
    />
  </head>
  <body
    class={bodyClassName}
    data-layout-mode={initialLayoutMode}
    data-route-home={String(isHomePage)}
    data-route-archive={String(isArchivePage)}
    data-route-post-editor={String(isPostEditorRoute)}
    data-overlayscrollbars-initialize
  >
    <ConfigCarrier resolvedSiteSettings={resolvedSiteSettings} />
    {
      gtmId && (
        <noscript>
          <iframe
            src={`https://www.googletagmanager.com/ns.html?id=${encodeURIComponent(gtmId)}`}
            height="0"
            width="0"
            style="display:none;visibility:hidden"
          />
        </noscript>
      )
    }
    <slot />

    <!-- Music Player - 仅在启用时加载 -->
    {
      musicPlayerSettings.enable && (
        <div id="music-player-shell" transition:persist>
          <MusicPlayer musicPlayer={musicPlayerSettings} client:idle />
        </div>
      )
    }

    <!-- 切页时临时增加页面高度，避免滚动动画跳变 -->
    <div id="page-height-extend" class="hidden h-[300vh]"></div>
    <!-- Vercel 可观测性 -->
    <Analytics />
    <SpeedInsights />
  </body>
</html>

<style
  is:global
  define:vars={{
    bannerOffset,
    "banner-height-home": bannerHeightHomeVh,
    "banner-height": bannerHeightVh,
  }}
>
  @reference "../styles/main.css";

  @layer components {
    body[data-layout-mode="banner"][data-route-home="true"] #banner-wrapper {
      @apply h-(--banner-height-home) translate-y-(--banner-height-extend);
    }
    body[data-layout-mode="banner"] #banner-wrapper {
      @apply h-(--banner-height-home);
    }
    body[data-layout-mode="banner"][data-route-home="true"] #banner {
      @apply h-(--banner-height-home) translate-y-0;
    }
    body[data-layout-mode="banner"] #banner {
      @apply h-(--banner-height-home) translate-y-(--bannerOffset);
    }

    /* 水波动画 */
    .waves > .parallax use {
      animation: wave 25s cubic-bezier(0.5, 0.5, 0.45, 0.5) infinite;
    }
    @keyframes wave {
      0% {
        transform: translate3d(-90px, 0, 0);
      }
      100% {
        transform: translate3d(85px, 0, 0);
      }
    }
  }
</style>

<script>
  import { bootstrapLayoutRuntime } from "../scripts/layout";

  bootstrapLayoutRuntime();
</script>

<!-- Mermaid 图表渲染 -->
<script>
  import "@/scripts/markdown/mermaid/runtime";
</script>

<!-- GitHub 卡片 runtime -->
<script>
  import "@/scripts/markdown/github-card-runtime";
</script>

<!-- 代码块折叠功能 -->
<script>
  import "@/scripts/markdown/code-collapse.js";
</script>

<!-- 登录提示覆盖层 -->
<script>
  import "@/scripts/shared/dialogs";
</script>

<!-- 主题切换综合性能优化器（包含代码块优化、重型元素优化、性能诊断） -->
<script>
  import "@/scripts/layout/theme-optimizer.js";
</script>
