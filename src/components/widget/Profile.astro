---
import { Icon } from "astro-icon/components";
import { getResolvedSiteSettings } from "@/server/site-settings/service";
import { resolveDisplayAvatarUrl } from "@/utils/profile-avatar";
import { url } from "@utils/url-utils";
import ImageWrapper from "../misc/ImageWrapper.astro";
import TypewriterText from "../TypewriterText.astro";
import { SOCIAL_PLATFORM_META } from "@constants/social-platforms";
import { loadOfficialSidebarProfile } from "@/server/api/v1/public-data";
import { runWithDirectusServiceAccess } from "@/server/directus/client";

import type { SidebarProfileData, SocialLink } from "@/types/app";

const resolvedSiteSettings =
  Astro.locals.siteSettings ?? (await getResolvedSiteSettings());
const profileConfig = resolvedSiteSettings.settings.profile;

// 动态侧栏数据：优先使用页面设置的 sidebarProfile，否则加载官方账户
let sidebarData: SidebarProfileData;
if (Astro.locals.sidebarProfile) {
  sidebarData = Astro.locals.sidebarProfile;
} else {
  sidebarData = await runWithDirectusServiceAccess(() =>
    loadOfficialSidebarProfile(),
  );
}

const displayName = sidebarData.display_name || "user";
const bio = sidebarData.bio || "";
const bioTypewriterEnable = sidebarData.bio_typewriter_enable ?? true;
const bioTypewriterSpeed = Math.max(
  10,
  Math.min(500, Math.floor(Number(sidebarData.bio_typewriter_speed) || 80)),
);
const avatarUrl = resolveDisplayAvatarUrl(
  sidebarData.avatar_url,
  profileConfig.avatar,
);
const profileLink = sidebarData.username
  ? url(`/${sidebarData.username}`)
  : url("/about");
const enabledLinks = (sidebarData.social_links || []).filter(
  (link: SocialLink) => link.enabled,
);
const socialLinkPayload = enabledLinks.map((link: SocialLink) => ({
  platform: String(link.platform || "").trim(),
  url: String(link.url || "").trim(),
}));
---

<div
  class="card-base p-3"
  data-sidebar-profile-root
  data-sidebar-profile-uid={sidebarData.username || "__official__"}
  data-sidebar-profile-name={displayName}
  data-sidebar-profile-bio={bio}
  data-sidebar-profile-avatar={avatarUrl}
  data-sidebar-profile-link={profileLink}
  data-sidebar-profile-social-links={JSON.stringify(socialLinkPayload)}
  data-sidebar-profile-social-mode={enabledLinks.length === 1
    ? "single"
    : "multi"}
>
  <a
    aria-label="Go to Profile Page"
    href={profileLink}
    data-sidebar-profile-link
    class="group block relative mx-auto mt-1 lg:mx-0 lg:mt-0 mb-3
       max-w-[12rem] lg:max-w-none overflow-hidden rounded-xl active:scale-95"
  >
    <div
      class="absolute transition pointer-events-none group-hover:bg-black/30 group-active:bg-black/50
        w-full h-full z-50 flex items-center justify-center"
    >
      <Icon
        name="fa7-regular:address-card"
        class="transition opacity-0 scale-90 group-hover:scale-100 group-hover:opacity-100 text-white text-5xl"
      />
    </div>
    <div
      data-sidebar-avatar-shell
      data-avatar-loading="true"
      class="relative mx-auto lg:w-full h-full lg:mt-0"
    >
      <div class="sidebar-avatar-skeleton" aria-hidden="true"></div>
      <div data-sidebar-profile-avatar class="mx-auto lg:w-full h-full lg:mt-0">
        <ImageWrapper
          src={avatarUrl}
          alt="Profile Image of the Author"
          class="mx-auto lg:w-full h-full lg:mt-0"
        />
      </div>
    </div>
  </a>
  <div class="px-2">
    <div
      data-sidebar-profile-name
      class="font-bold text-xl text-center mb-1 text-neutral-900 dark:text-neutral-50 transition"
    >
      {displayName}
    </div>
    <div class="h-1 w-5 bg-(--primary) mx-auto rounded-full mb-2 transition">
    </div>

    <div
      data-sidebar-profile-bio
      class="text-center text-neutral-500 dark:text-neutral-400 mb-2.5 transition"
    >
      {
        bioTypewriterEnable ? (
          <TypewriterText
            text={bio}
            speed={bioTypewriterSpeed}
            class="inline-block"
          />
        ) : (
          bio
        )
      }
    </div>

    <div
      data-sidebar-profile-social
      class="flex flex-wrap gap-2 justify-center mb-1"
    >
      {
        enabledLinks.length > 1 &&
          enabledLinks.map((item: SocialLink) => {
            const meta = SOCIAL_PLATFORM_META[item.platform];
            const icon = meta?.icon || "material-symbols:link";
            const label = meta?.label || item.platform;
            return (
              <a
                rel="me noopener noreferrer"
                aria-label={label}
                href={item.url}
                target="_blank"
                data-social-platform={item.platform}
                class="btn-regular rounded-lg h-10 w-10 active:scale-90"
              >
                <Icon name={icon} class="text-[1.5rem]" />
              </a>
            );
          })
      }
      {
        enabledLinks.length === 1 &&
          (() => {
            const item = enabledLinks[0];
            const meta = SOCIAL_PLATFORM_META[item.platform];
            const icon = meta?.icon || "material-symbols:link";
            const label = meta?.label || item.platform;
            return (
              <a
                rel="me noopener noreferrer"
                aria-label={label}
                href={item.url}
                target="_blank"
                data-social-platform={item.platform}
                class="btn-regular rounded-lg h-10 gap-2 px-3 font-bold active:scale-95"
              >
                <Icon name={icon} class="text-[1.5rem]" />
                {label}
              </a>
            );
          })()
      }
    </div>
  </div>
</div>
