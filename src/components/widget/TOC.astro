---
import type { MarkdownHeading } from "astro";

interface Props {
  id?: string;
  class?: string;
  style?: string;
  headings?: MarkdownHeading[];
}

const { id = "toc", style } = Astro.props;
const className = Astro.props.class;
---

<table-of-contents
  class:list={[className, "group"]}
  id={id}
  data-toc-root
  style={style}
>
  <!-- TOC 内容由客户端脚本运行时生成 -->
</table-of-contents>

<script>
  import "@/scripts/toc/element";
</script>

<style>
  table-of-contents[data-toc-root] {
    max-height: 100%;
    overflow: auto;
    position: relative;
    scroll-behavior: smooth;
    display: block;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  table-of-contents[data-toc-root][data-post-detail-sidebar="1"] {
    --toc-fade-height: 2.75rem;
    --toc-mask-image: none;
    max-height: var(--post-detail-toc-max-height, 100%);
    overflow-y: auto;
    overflow-x: hidden;
    -webkit-mask-image: var(--toc-mask-image);
    mask-image: var(--toc-mask-image);
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-size: 100% 100%;
    mask-size: 100% 100%;
  }

  table-of-contents[data-toc-root][data-post-detail-sidebar="1"][data-fade-top="0"][data-fade-bottom="1"] {
    --toc-mask-image: linear-gradient(
      to bottom,
      #000 0%,
      #000 calc(100% - var(--toc-fade-height)),
      transparent 100%
    );
  }

  table-of-contents[data-toc-root][data-post-detail-sidebar="1"][data-fade-top="1"][data-fade-bottom="0"] {
    --toc-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      #000 var(--toc-fade-height),
      #000 100%
    );
  }

  table-of-contents[data-toc-root][data-post-detail-sidebar="1"][data-fade-top="1"][data-fade-bottom="1"] {
    --toc-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      #000 var(--toc-fade-height),
      #000 calc(100% - var(--toc-fade-height)),
      transparent 100%
    );
  }

  table-of-contents[data-toc-root]::-webkit-scrollbar {
    display: none;
  }
</style>
