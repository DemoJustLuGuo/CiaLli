import RegisterFormSkeleton from "@components/auth/RegisterFormSkeleton.astro";
import PublishPageSkeleton from "@components/publish/PublishPageSkeleton.astro";

const settingsModes = [
  "admin-site-settings",
  "admin-bulletin-settings",
  "admin-about-settings",
  "me-settings",
] as const;

const staticPageModes = [
  "about-page",
  "friends-page",
  "stats-page",
  "bulletin-page",
] as const;

const feedModes = ["rss-page", "atom-page"] as const;
---

<template data-transition-proxy-shell="sidebar-main">
  <div class="relative max-w-(--page-width) mx-auto">
    <div
      class="main-panel-transition-proxy-grid grid grid-cols-[17.5rem_minmax(0,1fr)] gap-4 px-4"
    >
      <div
        class="main-panel-transition-proxy-sidebar mb-4 max-w-[17.5rem] col-start-1 col-end-2 row-start-1 row-end-2"
      >
        <TransitionProxySidebarSkeleton />
      </div>
      <main
        class="main-panel-transition-proxy-main transition-fade overflow-clip w-full col-span-1 row-start-1 row-end-2 col-start-2 col-end-3 relative"
      >
        <div
          data-transition-proxy-main-slot
          class="main-panel-transition-proxy-content"
        >
        </div>
      </main>
    </div>
  </div>
</template>

<template data-transition-proxy-shell="auth-login-split">
  <div class="relative max-w-(--page-width) mx-auto px-4">
    <AuthLoginShell
      proxyMainSlot={true}
      contentClass="main-panel-transition-proxy-content"
