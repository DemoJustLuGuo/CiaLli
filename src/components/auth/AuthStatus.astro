---
import { Icon } from "astro-icon/components";
import { url } from "@utils/url-utils";
---

<div id="auth-status" class="flex min-w-0 items-center gap-1">
  <a
    id="auth-login"
    href={url("/auth/login")}
    class="auth-status-btn btn-plain scale-animation rounded-lg w-11 h-11 active:scale-90 flex items-center justify-center"
    aria-label="Login"
    title="登录"
  >
    <Icon name="material-symbols:login-rounded" class="text-[1.25rem]" />
  </a>

  <div
    id="auth-user"
    class="hidden min-w-0 items-center gap-1.5 pl-1.5 pr-1 h-11 rounded-lg border border-(--line-divider) bg-(--card-bg)/50 lg:gap-2 lg:pl-2"
  >
    <a
      id="auth-account"
      href={url("/me")}
      class="flex items-center justify-center w-8 h-8 rounded-md overflow-hidden bg-black/5 dark:bg-white/10"
      aria-label="Account Settings"
      title="账户设置"
    >
      <img
        id="auth-user-avatar"
        src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw=="
        class="hidden w-full h-full object-cover"
        alt="用户头像"
        loading="lazy"
        decoding="async"
      />
      <Icon
        id="auth-user-icon"
        name="material-symbols:person-rounded"
        class="text-[1.25rem] text-black/70 dark:text-white/70"
      />
    </a>

    <span
      id="auth-user-name"
      class="hidden lg:block max-w-[7rem] text-sm text-black/70 dark:text-white/70 truncate"
    ></span>

    <a
      id="auth-admin"
      href="/admin"
      class="auth-status-btn auth-admin-only btn-plain scale-animation rounded-lg w-9 h-9 active:scale-90 items-center justify-center"
      aria-label="Admin"
      title="管理台"
    >
      <Icon
        name="material-symbols:admin-panel-settings-rounded"
        class="text-[1.1rem]"
      />
    </a>
  </div>
</div>

<style>
  .auth-status-btn {
    color: rgb(0 0 0 / 0.75);
  }

  :global(:root.dark) .auth-status-btn {
    color: rgb(255 255 255 / 0.75);
  }
</style>

<script>
  import {
    getAuthState,
    refreshAuthState,
    subscribeAuthState,
    type AuthState,
  } from "@/scripts/auth/state";
  import { buildLoginUrl } from "@utils/login-url";

  type AuthStatusRuntimeWindow = Window &
    typeof globalThis & {
      __cialliAuthStatusBound?: boolean;
    };

  type AuthDisplayUser = {
    name: string;
    avatarUrl: string;
  };

  const runtimeWindow = window as AuthStatusRuntimeWindow;

  function applyAvatarState(
    avatarEl: HTMLImageElement | null,
    iconEl: Element | null,
    avatarUrl: string | undefined,
  ): void {
    if (!avatarEl || !iconEl) return;
    if (avatarUrl) {
      avatarEl.src = avatarUrl;
      avatarEl.classList.remove("hidden");
      iconEl.classList.add("hidden");
    } else {
      avatarEl.removeAttribute("src");
      avatarEl.classList.add("hidden");
      iconEl.classList.remove("hidden");
    }
  }

  function applyLoggedInState(
    loginEl: Element,
    userEl: Element,
    userNameEl: Element,
    avatarEl: HTMLImageElement | null,
    iconEl: Element | null,
    adminEl: Element,
    user: AuthDisplayUser,
    isAdmin: boolean,
  ): void {
    loginEl.classList.add("hidden");
    userEl.classList.remove("hidden");
    userEl.classList.add("flex");
    userNameEl.textContent = user.name;
    applyAvatarState(avatarEl, iconEl, user.avatarUrl);
    if (isAdmin) {
      adminEl.classList.add("auth-admin-visible");
    } else {
      adminEl.classList.remove("auth-admin-visible");
    }
  }

  function applyLoggedOutState(
    loginEl: Element,
    userEl: Element,
    userNameEl: Element,
    avatarEl: HTMLImageElement | null,
    iconEl: Element | null,
    adminEl: Element,
  ): void {
    userEl.classList.add("hidden");
    userEl.classList.remove("flex");
    loginEl.classList.remove("hidden");
    userNameEl.textContent = "";
    applyAvatarState(avatarEl, iconEl, undefined);
    adminEl.classList.remove("auth-admin-visible");
  }

  type AuthElements = {
    loginEl: HTMLElement;
    userEl: HTMLElement;
    userNameEl: HTMLElement;
    avatarEl: HTMLImageElement | null;
    iconEl: HTMLElement | null;
    adminEl: HTMLElement;
  };

  function queryAuthElements(): AuthElements | null {
    const loginEl = document.getElementById("auth-login");
    const userEl = document.getElementById("auth-user");
    const userNameEl = document.getElementById("auth-user-name");
    const adminEl = document.getElementById("auth-admin");
    if (!loginEl || !userEl || !userNameEl || !adminEl) return null;
    const avatarEl = document.getElementById(
      "auth-user-avatar",
    ) as HTMLImageElement | null;
    const iconEl = document.getElementById("auth-user-icon");
    return {
      loginEl,
      userEl,
      userNameEl,
      avatarEl,
      iconEl,
      adminEl,
    };
  }

  function resolveDisplayUser(state: AuthState): AuthDisplayUser {
    return {
      name:
        state.displayName ||
        state.username ||
        state.email ||
        (state.userId ? `user-${state.userId.slice(0, 8)}` : "Member"),
      avatarUrl: state.avatarUrl || "",
    };
  }

  function applyAuthStatusState(state: AuthState): void {
    const els = queryAuthElements();
    if (!els) {
      return;
    }

    const { loginEl, userEl, userNameEl, avatarEl, iconEl, adminEl } = els;
    loginEl.setAttribute("href", buildLoginUrl());

    if (state.isLoggedIn) {
      applyLoggedInState(
        loginEl,
        userEl,
        userNameEl,
        avatarEl,
        iconEl,
        adminEl,
        resolveDisplayUser(state),
        state.isAdmin,
      );
      return;
    }

    applyLoggedOutState(loginEl, userEl, userNameEl, avatarEl, iconEl, adminEl);
  }

  function bindAvatarFallback(): void {
    const avatarEl = document.getElementById(
      "auth-user-avatar",
    ) as HTMLImageElement | null;
    const iconEl = document.getElementById("auth-user-icon");

    if (avatarEl && iconEl && !avatarEl.dataset.bound) {
      avatarEl.dataset.bound = "1";
      avatarEl.addEventListener("error", () => {
        avatarEl.removeAttribute("src");
        avatarEl.classList.add("hidden");
        iconEl.classList.remove("hidden");
      });
    }
  }

  function initAuthStatus(): void {
    bindAvatarFallback();
    applyAuthStatusState(getAuthState());
    void refreshAuthState();
  }

  if (!runtimeWindow.__cialliAuthStatusBound) {
    runtimeWindow.__cialliAuthStatusBound = true;
    subscribeAuthState((state) => {
      applyAuthStatusState(state);
    });
    document.addEventListener("astro:after-swap", initAuthStatus);
  }

  initAuthStatus();
</script>

<style>
  .auth-admin-only {
    display: none;
  }

  .auth-admin-only.auth-admin-visible {
    display: flex;
  }
</style>
