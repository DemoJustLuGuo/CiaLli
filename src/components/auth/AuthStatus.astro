---
import { Icon } from "astro-icon/components";
import { url } from "@utils/url-utils";
---

<div id="auth-status" class="flex min-w-0 items-center gap-1">
  <a
    id="auth-login"
    href={url("/auth/login")}
    class="btn-plain scale-animation rounded-lg w-11 h-11 active:scale-90 flex items-center justify-center"
    aria-label="Login"
    title="登录"
  >
    <Icon name="material-symbols:login-rounded" class="text-[1.25rem]" />
  </a>

  <div
    id="auth-user"
    class="hidden min-w-0 items-center gap-2 pl-2 pr-1 h-11 rounded-lg border border-(--line-divider) bg-(--card-bg)/50"
  >
    <a
      id="auth-account"
      href="/me"
      class="flex items-center justify-center w-8 h-8 rounded-md overflow-hidden bg-black/5 dark:bg-white/10"
      aria-label="Account Settings"
      title="账户设置"
    >
      <img
        id="auth-user-avatar"
        src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw=="
        class="hidden w-full h-full object-cover"
        alt="用户头像"
        loading="lazy"
        decoding="async"
      />
      <Icon
        id="auth-user-icon"
        name="material-symbols:person-rounded"
        class="text-[1.25rem] text-black/70 dark:text-white/70"
      />
    </a>

    <span
      id="auth-user-name"
      class="block max-w-[7rem] text-sm text-black/70 dark:text-white/70 truncate"
    ></span>

    <a
      id="auth-admin"
      href="/admin"
      class="auth-admin-only btn-plain scale-animation rounded-lg w-9 h-9 active:scale-90 items-center justify-center"
      aria-label="Admin"
      title="管理台"
    >
      <Icon
        name="material-symbols:admin-panel-settings-rounded"
        class="text-[1.1rem]"
      />
    </a>

    <button
      id="auth-logout"
      type="button"
      class="btn-plain scale-animation rounded-lg w-9 h-9 active:scale-90 flex items-center justify-center"
      aria-label="Logout"
      title="退出"
    >
      <Icon name="material-symbols:logout-rounded" class="text-[1.1rem]" />
    </button>
  </div>
</div>

<script>
  import { emitAuthState } from "@/scripts/auth-state";
  import { buildLoginUrl } from "@utils/login-url";
  import { getCsrfToken } from "@/utils/csrf";

  const API_ME = "/api/auth/me";
  const API_LOGOUT = "/api/auth/logout";
  const AUTH_ME_RETRY_DELAY_MS = 220;
  type AuthPayload = {
    ok?: boolean;
    isAdmin?: boolean;
    is_admin?: boolean;
    user?: {
      id?: string;
      username?: string;
      name?: string;
      email?: string;
      avatarUrl?: string;
    };
  };

  let initTask: Promise<void> | null = null;

  function publishAuthState(
    isLoggedIn: boolean,
    isAdmin: boolean,
    userId: string,
    username: string,
  ) {
    emitAuthState({
      isLoggedIn,
      isAdmin,
      userId: userId || "",
      username: username || "",
    });
  }

  function applyAvatarState(
    avatarEl: HTMLImageElement | null,
    iconEl: Element | null,
    avatarUrl: string | undefined,
  ): void {
    if (!avatarEl || !iconEl) return;
    if (avatarUrl) {
      avatarEl.src = avatarUrl;
      avatarEl.classList.remove("hidden");
      iconEl.classList.add("hidden");
    } else {
      avatarEl.removeAttribute("src");
      avatarEl.classList.add("hidden");
      iconEl.classList.remove("hidden");
    }
  }

  function applyLoggedInState(
    loginEl: Element,
    userEl: Element,
    userNameEl: Element,
    avatarEl: HTMLImageElement | null,
    iconEl: Element | null,
    adminEl: Element,
    user: AuthPayload["user"],
    isAdmin: boolean,
  ): void {
    loginEl.classList.add("hidden");
    userEl.classList.remove("hidden");
    userEl.classList.add("flex");
    userNameEl.textContent =
      user?.name || user?.username || user?.email || "Member";
    applyAvatarState(avatarEl, iconEl, user?.avatarUrl);
    if (isAdmin) {
      adminEl.classList.add("auth-admin-visible");
    } else {
      adminEl.classList.remove("auth-admin-visible");
    }
  }

  function applyLoggedOutState(
    loginEl: Element,
    userEl: Element,
    userNameEl: Element,
    avatarEl: HTMLImageElement | null,
    iconEl: Element | null,
    adminEl: Element,
  ): void {
    userEl.classList.add("hidden");
    userEl.classList.remove("flex");
    loginEl.classList.remove("hidden");
    userNameEl.textContent = "";
    applyAvatarState(avatarEl, iconEl, undefined);
    adminEl.classList.remove("auth-admin-visible");
  }

  type AuthElements = {
    loginEl: HTMLElement;
    userEl: HTMLElement;
    userNameEl: HTMLElement;
    avatarEl: HTMLImageElement | null;
    iconEl: HTMLElement | null;
    adminEl: HTMLElement;
  };

  function queryAuthElements(): AuthElements | null {
    const loginEl = document.getElementById("auth-login");
    const userEl = document.getElementById("auth-user");
    const userNameEl = document.getElementById("auth-user-name");
    const adminEl = document.getElementById("auth-admin");
    if (!loginEl || !userEl || !userNameEl || !adminEl) return null;
    const avatarEl = document.getElementById(
      "auth-user-avatar",
    ) as HTMLImageElement | null;
    const iconEl = document.getElementById("auth-user-icon");
    return { loginEl, userEl, userNameEl, avatarEl, iconEl, adminEl };
  }

  type AuthInfo = {
    userId: string;
    username: string;
    isLoggedIn: boolean;
    isAdmin: boolean;
    user: AuthPayload["user"];
  };

  function extractAuthInfo(state: AuthPayload | null): AuthInfo {
    const userId = state?.user?.id ? String(state.user.id) : "";
    const username = state?.user?.username ? String(state.user.username) : "";
    const user = state?.user;
    const isLoggedIn = Boolean(userId);
    const adminFlag = state?.isAdmin ?? state?.is_admin ?? false;
    const isAdmin = Boolean(isLoggedIn && adminFlag);
    return { userId, username, isLoggedIn, isAdmin, user };
  }

  function setAuthState(state: AuthPayload | null): void {
    const info = extractAuthInfo(state);
    const { userId, username, isLoggedIn, isAdmin, user } = info;

    const els = queryAuthElements();
    if (!els) {
      publishAuthState(isLoggedIn, isAdmin, userId, username);
      return;
    }

    const { loginEl, userEl, userNameEl, avatarEl, iconEl, adminEl } = els;
    loginEl.setAttribute("href", buildLoginUrl());

    if (isLoggedIn && user) {
      applyLoggedInState(
        loginEl,
        userEl,
        userNameEl,
        avatarEl,
        iconEl,
        adminEl,
        user,
        isAdmin,
      );
      publishAuthState(isLoggedIn, isAdmin, userId, username);
      return;
    }

    applyLoggedOutState(loginEl, userEl, userNameEl, avatarEl, iconEl, adminEl);
    publishAuthState(false, false, "", "");
  }

  async function refreshAuthState() {
    const load = async () => {
      const response = await fetch(API_ME, {
        method: "GET",
        credentials: "include",
        headers: { Accept: "application/json" },
        cache: "no-store",
      });
      const data = await response.json().catch(() => null);
      return { response, data };
    };

    try {
      let { response, data } = await load();
      if ((!response.ok || !data?.ok) && response.status === 401) {
        await new Promise((resolve) =>
          window.setTimeout(resolve, AUTH_ME_RETRY_DELAY_MS),
        );
        ({ response, data } = await load());
      }
      if (!response.ok || !data?.ok) {
        setAuthState(null);
        return;
      }
      setAuthState({ ...data, isAdmin: Boolean(data?.is_admin) });
    } catch (error) {
      console.error("Failed to load auth state:", error);
      setAuthState(null);
    }
  }

  async function initAuthStatus() {
    if (initTask) {
      await initTask;
      return;
    }
    initTask = (async () => {
      const logoutBtn = document.getElementById("auth-logout");
      const avatarEl = document.getElementById(
        "auth-user-avatar",
      ) as HTMLImageElement | null;
      const iconEl = document.getElementById("auth-user-icon");

      if (avatarEl && iconEl && !avatarEl.dataset.bound) {
        avatarEl.dataset.bound = "1";
        avatarEl.addEventListener("error", () => {
          avatarEl.removeAttribute("src");
          avatarEl.classList.add("hidden");
          iconEl.classList.remove("hidden");
        });
      }

      if (logoutBtn && !logoutBtn.dataset.bound) {
        logoutBtn.dataset.bound = "1";
        logoutBtn.addEventListener("click", async () => {
          try {
            await fetch(API_LOGOUT, {
              method: "POST",
              credentials: "include",
              headers: {
                "Content-Type": "application/json",
                "x-csrf-token": getCsrfToken(),
              },
              body: JSON.stringify({}),
            });
          } catch (error) {
            console.error("Logout failed:", error);
          } finally {
            setAuthState(null);
            window.location.href = "/";
          }
        });
      }

      await refreshAuthState();
    })();
    try {
      await initTask;
    } finally {
      initTask = null;
    }
  }

  initAuthStatus();
  document.addEventListener("astro:after-swap", initAuthStatus);
</script>

<style>
  .auth-admin-only {
    display: none;
  }

  .auth-admin-only.auth-admin-visible {
    display: flex;
  }
</style>
