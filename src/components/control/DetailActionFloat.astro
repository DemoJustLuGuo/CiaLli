---
import { Icon } from "astro-icon/components";

interface Props {
  contentType: "article" | "diary";
  contentId: string;
  authorId: string;
  likeCount?: number;
  commentCount?: number;
  likedByViewer?: boolean;
  editHref?: string;
  deleteEndpoint?: string;
  deleteConfirmMessage?: string;
  deleteSuccessHref?: string;
}

const {
  contentType,
  contentId,
  authorId,
  likeCount = 0,
  commentCount = 0,
  likedByViewer = false,
  editHref = "",
  deleteEndpoint = "",
  deleteConfirmMessage = "确认删除该内容？删除后不可恢复。",
  deleteSuccessHref = "/",
} = Astro.props;
---

<div
  class="detail-action-float"
  data-content-type={contentType}
  data-content-id={contentId}
  data-author-id={authorId}
  data-like-count={String(likeCount)}
  data-comment-count={String(commentCount)}
  data-liked={likedByViewer ? "1" : "0"}
  data-edit-href={editHref}
  data-delete-endpoint={deleteEndpoint}
  data-delete-confirm-message={deleteConfirmMessage}
  data-delete-success-href={deleteSuccessHref}
>
  <div class="detail-action-bar card-base rounded-2xl">
    <button
      type="button"
      class="detail-action-btn detail-like-btn"
      aria-label="点赞"
    >
      <Icon name="material-symbols:thumb-up-rounded" class="detail-icon" />
      <span class="detail-action-count" data-like-count-text>{likeCount}</span>
    </button>
    <button
      type="button"
      class="detail-action-btn detail-comment-btn"
      aria-label="查看评论"
    >
      <Icon name="material-symbols:comment-rounded" class="detail-icon" />
      <span class="detail-action-count">{commentCount}</span>
    </button>
    <button
      type="button"
      class="detail-action-btn detail-manage-toggle hidden"
      aria-label="更多操作"
    >
      <Icon name="material-symbols:more-horiz" class="detail-icon" />
    </button>
  </div>

  <div class="detail-manage-panel">
    <button
      type="button"
      class="detail-manage-edit hidden w-full text-left px-3 py-2 rounded-lg text-sm text-90 hover:bg-black/5 dark:hover:bg-white/10"
    >
      编辑
    </button>
    <button
      type="button"
      class="detail-manage-delete hidden w-full text-left px-3 py-2 rounded-lg text-sm text-red-500 hover:bg-black/5 dark:hover:bg-white/10"
    >
      删除
    </button>
  </div>
</div>

<style lang="stylus">
  .detail-action-float
    position: relative
    width: 3.75rem
    margin-top: 9.5rem
    margin-left: 0
    margin-right: auto
    z-index: 30

    &.fixed-mode
      position: fixed
      right: 1rem
      top: 36%
      margin: 0

    &.slot-mode
      margin-top: .5rem

  .detail-action-bar
    width: 3.75rem
    display: flex
    flex-direction: column
    align-items: center
    padding: .4rem
    gap: .15rem
    border: 1px solid var(--line-divider)

  .detail-action-btn
    width: 100%
    min-height: 3.35rem
    border: none
    background: transparent
    border-radius: .85rem
    display: flex
    flex-direction: column
    align-items: center
    justify-content: center
    gap: .25rem
    color: var(--btn-content)
    transition: background-color .2s ease, color .2s ease

    &:hover
      background: var(--btn-card-bg-active)

    &.active
      color: var(--primary)

    &:disabled
      opacity: .65
      cursor: not-allowed

  .detail-icon
    font-size: 1.65rem

  .detail-action-count
    font-size: .95rem
    line-height: 1
    color: var(--text-60)

  .detail-manage-panel
    position: absolute
    bottom: 0
    left: calc(100% + .4rem)
    min-width: 8rem
    z-index: 60
    background: var(--card-bg)
    border: 1px solid var(--line-divider)
    border-radius: 1rem
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15)
    padding: 0.5rem
    opacity: 0
    visibility: hidden
    transform: translate(-6px, 6px) scale(0.95)
    transition: all 0.2s ease
    pointer-events: none

    &.show
      opacity: 1
      visibility: visible
      transform: translate(0, 0) scale(1)
      pointer-events: auto

  .detail-action-float.fixed-mode .detail-manage-panel
    left: auto
    right: calc(100% + .4rem)
    transform: translate(6px, 6px) scale(0.95)

  .detail-action-float.fixed-mode .detail-manage-panel.show
    transform: translate(0, 0) scale(1)

</style>

<script>
  import { getAuthState, subscribeAuthState } from "@/scripts/auth-state";
  import type { AuthState } from "@/scripts/auth-state";
  import {
    showAuthRequiredDialog,
    showConfirmDialog,
    showNoticeDialog,
  } from "@/scripts/dialogs";
  import { navigateToPage } from "@/utils/navigation-utils";
  import { getCsrfToken } from "@/utils/csrf";

  function initDetailActionFloat(): void {
    const roots = document.querySelectorAll<HTMLElement>(
      ".detail-action-float:not([data-bound='1'])",
    );

    roots.forEach((rootEl) => {
      rootEl.dataset.bound = "1";

      const customSlot = document.querySelector<HTMLElement>(
        "[data-detail-float-slot]",
      );
      const canMountToCustomSlot =
        customSlot instanceof HTMLElement &&
        window.getComputedStyle(customSlot).display !== "none";

      if (canMountToCustomSlot && rootEl.parentElement !== customSlot) {
        customSlot.appendChild(rootEl);
      }

      const rightSidebarSlot = document.getElementById("right-sidebar-slot");
      const tocWrapper = document.querySelector<HTMLElement>(
        "#right-sidebar-slot #toc-wrapper",
      );
      const tocRoot = document.querySelector<HTMLElement>(
        "#right-sidebar-slot #toc",
      );
      const mountTarget =
        tocWrapper || tocRoot?.parentElement || rightSidebarSlot || null;
      const canMountToSidebar =
        mountTarget instanceof HTMLElement &&
        window.getComputedStyle(mountTarget).display !== "none";
      if (
        !canMountToCustomSlot &&
        canMountToSidebar &&
        rootEl.parentElement !== mountTarget
      ) {
        mountTarget.appendChild(rootEl);
      }

      const sidebarHidden =
        !canMountToCustomSlot && (!mountTarget || !canMountToSidebar);
      rootEl.classList.toggle("slot-mode", canMountToCustomSlot);
      rootEl.classList.toggle("fixed-mode", sidebarHidden);

      const contentType = String(rootEl.dataset.contentType || "");
      const contentId = String(rootEl.dataset.contentId || "");
      const authorId = String(rootEl.dataset.authorId || "");
      const editHref = String(rootEl.dataset.editHref || "");
      const deleteEndpoint = String(rootEl.dataset.deleteEndpoint || "");
      const deleteConfirmMessage = String(
        rootEl.dataset.deleteConfirmMessage ||
          "确认删除该内容？删除后不可恢复。",
      );
      const deleteSuccessHref = String(rootEl.dataset.deleteSuccessHref || "/");

      const likeBtn =
        rootEl.querySelector<HTMLButtonElement>(".detail-like-btn");
      const commentBtn = rootEl.querySelector<HTMLButtonElement>(
        ".detail-comment-btn",
      );
      const manageBtn = rootEl.querySelector<HTMLButtonElement>(
        ".detail-manage-toggle",
      );
      const panel = rootEl.querySelector<HTMLElement>(".detail-manage-panel");
      const editBtn = rootEl.querySelector<HTMLButtonElement>(
        ".detail-manage-edit",
      );
      const deleteBtn = rootEl.querySelector<HTMLButtonElement>(
        ".detail-manage-delete",
      );
      const likeCountText = rootEl.querySelector<HTMLElement>(
        "[data-like-count-text]",
      );

      let liked = rootEl.dataset.liked === "1";
      let likeCount = Number(rootEl.dataset.likeCount || "0") || 0;
      let isOpen = false;
      let likePending = false;

      function applyLikeUI(): void {
        const normalizedLikeCount = Math.max(0, likeCount);
        likeCount = normalizedLikeCount;
        rootEl.dataset.liked = liked ? "1" : "0";
        rootEl.dataset.likeCount = String(normalizedLikeCount);
        likeBtn?.classList.toggle("active", liked);
        likeBtn?.classList.toggle("is-pending", likePending);
        if (likeBtn) {
          likeBtn.disabled = likePending;
        }
        if (likeCountText) {
          likeCountText.textContent = String(normalizedLikeCount);
        }
      }

      function applyActionVisibility(state: AuthState): void {
        const canManage =
          state.isLoggedIn &&
          Boolean(state.userId) &&
          (state.isAdmin || state.userId === authorId);
        const canOpenPanel = canManage || state.isLoggedIn;

        manageBtn?.classList.toggle("hidden", !canOpenPanel);
        editBtn?.classList.toggle("hidden", !canManage);
        deleteBtn?.classList.toggle("hidden", !canManage);

        if (!canOpenPanel && isOpen) {
          panel?.classList.remove("show");
          isOpen = false;
        }
      }

      function openPanel(): void {
        isOpen = true;
        panel?.classList.add("show");
        manageBtn?.classList.add("active");
      }

      function closePanel(): void {
        isOpen = false;
        panel?.classList.remove("show");
        manageBtn?.classList.remove("active");
      }

      applyLikeUI();
      applyActionVisibility(getAuthState());

      subscribeAuthState((state) => {
        applyActionVisibility(state);
      });

      manageBtn?.addEventListener("click", (event) => {
        event.stopPropagation();
        if (isOpen) {
          closePanel();
        } else {
          openPanel();
        }
      });

      document.addEventListener("click", (event) => {
        if (!isOpen) return;
        if (!rootEl.contains(event.target as Node)) {
          closePanel();
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && isOpen) {
          closePanel();
        }
      });

      editBtn?.addEventListener("click", () => {
        if (!editHref) {
          return;
        }
        closePanel();
        navigateToPage(editHref, {
          force: contentType === "diary",
        });
      });

      deleteBtn?.addEventListener("click", async () => {
        if (!deleteEndpoint) {
          return;
        }
        const confirmed = await showConfirmDialog({
          ariaLabel: "删除确认",
          message: deleteConfirmMessage,
          confirmText: "确认删除",
          cancelText: "取消",
          confirmVariant: "danger",
        });
        if (!confirmed) {
          closePanel();
          return;
        }

        deleteBtn.disabled = true;
        try {
          const response = await fetch(deleteEndpoint, {
            method: "DELETE",
            credentials: "include",
            headers: {
              Accept: "application/json",
              "x-csrf-token": getCsrfToken(),
            },
          });
          const data = await response.json().catch(() => null);
          if (!response.ok || !data?.ok) {
            await showNoticeDialog({
              ariaLabel: "删除失败",
              message: data?.error?.message || "删除失败",
            });
            return;
          }
          navigateToPage(deleteSuccessHref || "/");
        } catch (error) {
          console.error(`[detail-action] delete ${contentType} failed:`, error);
          await showNoticeDialog({
            ariaLabel: "删除失败",
            message: "删除失败，请稍后重试。",
          });
        } finally {
          deleteBtn.disabled = false;
          closePanel();
        }
      });

      likeBtn?.addEventListener("click", async () => {
        if (likePending || !contentId) {
          return;
        }

        const auth = getAuthState();
        if (!auth.isLoggedIn) {
          showAuthRequiredDialog();
          return;
        }

        const previousLiked = liked;
        const previousLikeCount = likeCount;
        liked = !previousLiked;
        likeCount = Math.max(0, previousLikeCount + (liked ? 1 : -1));

        likePending = true;
        applyLikeUI();
        try {
          const endpoint =
            contentType === "diary"
              ? "/api/v1/me/diary-likes"
              : "/api/v1/me/article-likes";
          const body =
            contentType === "diary"
              ? { diary_id: contentId }
              : { article_id: contentId };
          const response = await fetch(endpoint, {
            method: "POST",
            credentials: "include",
            headers: {
              "content-type": "application/json",
              "x-csrf-token": getCsrfToken(),
            },
            body: JSON.stringify(body),
          });
          const data = await response.json().catch(() => null);
          if (!response.ok || !data?.ok) {
            throw new Error(
              data?.error?.message || "点赞操作失败，请稍后重试。",
            );
          }

          liked = Boolean(data?.liked);
          likeCount = Number(data?.like_count || 0);
          applyLikeUI();
        } catch (error) {
          console.error("[detail-action] like request failed:", error);
          liked = previousLiked;
          likeCount = previousLikeCount;
          applyLikeUI();
          await showNoticeDialog({
            ariaLabel: "点赞失败",
            message:
              error instanceof Error && error.message
                ? error.message
                : "点赞操作失败，请稍后重试。",
          });
        } finally {
          likePending = false;
          applyLikeUI();
        }
      });

      commentBtn?.addEventListener("click", () => {
        const commentRoot = document.getElementById("comment-root");
        if (commentRoot) {
          commentRoot.scrollIntoView({ behavior: "smooth", block: "start" });
          return;
        }
        navigateToPage(`${window.location.pathname}#comment-root`);
      });
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initDetailActionFloat, {
      once: true,
    });
  } else {
    initDetailActionFloat();
  }

  document.addEventListener("astro:after-swap", initDetailActionFloat);
</script>
