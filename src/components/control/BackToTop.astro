---
import { Icon } from "astro-icon/components";
---

<!-- There can't be a filter on parent element, or it will break `fixed` -->
<div class="back-to-top-wrapper block">
  <div
    id="back-to-top-btn"
    class="back-to-top-btn hide flex items-center rounded-2xl overflow-hidden transition"
    onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
  >
    <button aria-label="Back to Top" class="btn-card back-to-top-btn-inner">
      <Icon name="material-symbols:keyboard-arrow-up-rounded" class="mx-auto" />
    </button>
  </div>
</div>

<style lang="stylus">
  .back-to-top-wrapper
    width: var(--right-float-size, 3.75rem)
    height: var(--right-float-size, 3.75rem)
    position: absolute
    right: 0
    top: 0
    pointer-events: none

  .back-to-top-btn-inner
    width: var(--right-float-size, 3.75rem)
    height: var(--right-float-size, 3.75rem)
    border-radius: inherit

  .back-to-top-btn
    color: var(--primary)
    font-size: 2.25rem
    font-weight: bold
    border: none
    position: fixed
    z-index: var(--z-float-rail, 70)
    bottom: var(--back-to-top-bottom, 10rem)
    opacity: 1
    right: var(--right-float-right, 6rem)
    cursor: pointer
    transform: translateX(var(--right-float-shift-x, 5rem))
    pointer-events: auto
    transition: box-shadow 1s ease-in-out

    i
      font-size: 1.75rem

    &.hide
      transform: translateX(var(--right-float-shift-x, 5rem)) scale(0.9)
      opacity: 0
      pointer-events: none

    &:active
      transform: translateX(var(--right-float-shift-x, 5rem)) scale(0.9)

  @media (max-width: 1279px)
    .back-to-top-wrapper
      width: var(--mobile-float-size, 3.2rem)
      height: var(--mobile-float-size, 3.2rem)

    .back-to-top-btn-inner.btn-card
      width: var(--mobile-float-size, 3.2rem)
      height: var(--mobile-float-size, 3.2rem)
      color: var(--mobile-float-control-content)
      background: var(--mobile-float-control-bg)

      &:hover
        background: var(--mobile-float-control-bg-hover)

      &:active
        background: var(--mobile-float-control-bg-active)

    .back-to-top-btn
      font-size: 2rem
      right: var(--mobile-float-rail-right, 1rem)
      bottom: calc(var(--mobile-float-rail-bottom, 1rem) + (var(--mobile-float-size, 3.75rem) + var(--mobile-float-gap, 0.75rem)) * var(--mobile-float-launcher-count, 0) + 0.85rem)
      transform: none
      overflow: visible
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.12)

      &.hide
        transform: scale(0.9)

      &:active
        transform: scale(0.9)
</style>
