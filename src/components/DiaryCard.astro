---
import { Icon } from "astro-icon/components";

import ExternalImage from "@components/misc/ExternalImage.astro";
import type { AppDiary, AppDiaryImage } from "@/types/app";
import type { AuthorBundleItem } from "@/server/api/v1/shared/author-cache";
import type { HomeFeedViewerState } from "@/server/recommendation/home-feed.types";
import { buildPublicAssetUrl } from "@/server/directus-auth";
import { getResolvedSiteSettings } from "@/server/site-settings/service";
import { resolveAuthorIdentity } from "@/utils/author-identity";
import { resolveDiaryDisplayDateSource } from "@/utils/diary-date";
import { buildSiteDateFormatContext, formatSiteDate } from "@/utils/date-utils";

interface Props {
  class?: string;
  entry: AppDiary & {
    author: AuthorBundleItem;
    images: AppDiaryImage[];
    comment_count: number;
    like_count: number;
  };
  username: string;
  viewerState?: HomeFeedViewerState;
  displayDateOverride?: Date | string | null;
  titleSerif?: boolean;
}

const { entry, username } = Astro.props;
const className = Astro.props.class;
const titleSerif = Astro.props.titleSerif === true;
const displayDateOverride = Astro.props.displayDateOverride;
const viewerState: HomeFeedViewerState = Astro.props.viewerState ?? {
  hasLiked: false,
  canDeleteOwn: false,
  canDeleteAdmin: false,
};
const resolvedSiteSettings =
  Astro.locals.siteSettings ?? (await getResolvedSiteSettings());
const siteDateContext = buildSiteDateFormatContext(resolvedSiteSettings);

const {
  id,
  short_id,
  content,
  date_created,
  author,
  author_id,
  images,
  comment_count,
  like_count,
} = entry;

const diaryUrl = `/${username}/diary/${short_id || id}`;
const { displayName: authorDisplayName, username: authorHandle } =
  resolveAuthorIdentity(
    {
      id: author?.id,
      name: author?.name,
      username: author?.username,
      display_name: author?.display_name,
    },
    author_id,
  );

const bodyText = String(content || "")
  .replace(/<[^>]+>/g, " ")
  .replace(/\s+/g, " ")
  .trim();
const excerpt =
  bodyText.length > 180 ? `${bodyText.slice(0, 180)}...` : bodyText;

const publishedDateSource = resolveDiaryDisplayDateSource(
  displayDateOverride,
  date_created,
);
const publishedDate = publishedDateSource
  ? (() => {
      const formattedDate = formatSiteDate(
        publishedDateSource,
        siteDateContext,
      );
      return formattedDate || "1970/01/01";
    })()
  : "1970/01/01";

const visibleImages = (images || [])
  .filter((img) => img.image_url || img.file_id)
  .slice(0, 4);

function resolveDiaryImageSrc(image: AppDiaryImage): string {
  const imageUrl = String(image.image_url || "").trim();
  if (imageUrl.startsWith("http://") || imageUrl.startsWith("https://")) {
    return imageUrl;
  }
  if (imageUrl.startsWith("/")) {
    return imageUrl;
  }
  const assetId = String(image.file_id || imageUrl).trim();
  if (!assetId) {
    return "";
  }
  return buildPublicAssetUrl(assetId, {
    width: 200,
    height: 200,
    fit: "cover",
  });
}
---

<div
  class:list={[
    "card-base flex flex-col w-full rounded-(--radius-large) overflow-hidden relative",
    className,
  ]}
  data-diary-card
  data-diary-id={id}
  data-author-id={author_id}
  data-author-handle={authorHandle}
>
  <div
    class="diary-card-body relative flex flex-col gap-4 px-5 py-5 lg:pl-9 lg:pr-2 lg:pt-7 lg:pb-6"
  >
    <a href={diaryUrl} class="flex flex-col gap-3">
      <p
        class:list={[
          "diary-card-excerpt transition text-75 pr-0 line-clamp-2 text-base leading-7 lg:pr-4",
          {
            "font-content-serif": titleSerif,
          },
        ]}
      >
        {excerpt}
      </p>
      {
        visibleImages.length > 0 && (
          <div class="grid grid-cols-2 gap-2 sm:grid-cols-4">
            {visibleImages.map((img) => (
              <ExternalImage
                src={resolveDiaryImageSrc(img)}
                alt="日记配图"
                class="w-full h-24 object-cover rounded-lg border border-(--line-divider)"
                loading="lazy"
              />
            ))}
          </div>
        )
      }
    </a>

    <div
      class="flex flex-col items-start gap-3 mt-4 lg:flex-row lg:items-center lg:justify-between"
    >
      <div
        class="diary-card-meta diary-card-muted-text flex min-w-0 flex-wrap items-center gap-1.5 text-sm font-medium leading-none"
      >
        <div class="max-w-[14rem] min-w-0 inline-flex items-baseline gap-1">
          <a
            href={`/${authorHandle}`}
            class="diary-card-primary-text truncate border-b border-transparent hover:border-current"
          >
            {authorDisplayName}
          </a>
          <a
            href={`/${authorHandle}`}
            class="diary-card-secondary-text shrink-0 hover:text-(--primary) transition-colors"
          >
            {"@"}
            {authorHandle}
          </a>
        </div>
        <span class="diary-card-muted-text" aria-hidden="true">&middot;</span>
        <span>{publishedDate}</span>
      </div>
      <div
        class="flex w-full items-center justify-between gap-4 shrink-0 post-card-actions leading-none lg:ml-3 lg:mr-2 lg:w-auto lg:justify-start"
      >
        <button
          type="button"
          class:list={[
            "diary-card-action-control inline-flex h-6 items-center gap-1.5 text-base font-medium hover:text-(--primary) transition-colors post-card-action-btn",
            {
              "text-(--primary)": viewerState.hasLiked,
              "diary-card-muted-text": !viewerState.hasLiked,
            },
          ]}
          data-action="toggle-like"
          data-liked={viewerState.hasLiked ? "true" : "false"}
          data-like-count={like_count}
          aria-label="切换点赞"
        >
          <Icon
            name="material-symbols:thumb-up-rounded"
            class="diary-card-action-icon text-xl"
          />
          <span data-like-count>{like_count}</span>
        </button>
        <a
          href={`${diaryUrl}#comment-root`}
          class="diary-card-action-control diary-card-muted-text inline-flex h-6 items-center gap-1.5 text-base font-medium hover:text-(--primary) transition-colors"
        >
          <Icon
            name="material-symbols:comment-rounded"
            class="diary-card-action-icon text-xl"
          />
          <span>{comment_count}</span>
        </a>
        <details class="relative post-card-menu">
          <summary
            class="diary-card-action-menu diary-card-muted-text list-none cursor-pointer inline-flex items-center justify-center w-8 h-8 rounded-lg hover:text-(--primary) hover:bg-(--btn-plain-bg-hover) active:bg-(--btn-plain-bg-active) transition-colors"
            aria-label="更多操作"
          >
            <Icon
              name="material-symbols:more-horiz"
              class="diary-card-action-icon text-xl"
            />
          </summary>
          <div
            class="absolute right-0 bottom-full mb-2 z-30 min-w-[10rem] rounded-xl border border-black/5 dark:border-white/10 bg-(--float-panel-bg) p-1.5 shadow-xl dark:shadow-none"
          >
            <button
              type="button"
              class:list={[
                "diary-card-panel-text w-full text-left px-3 py-2 text-sm rounded-lg hover:text-(--primary) hover:bg-(--btn-plain-bg-hover) post-card-action-btn transition-colors",
                {
                  hidden: !viewerState.canDeleteOwn,
                },
              ]}
              data-action="delete-own-diary"
            >
              删除日记
            </button>
            <button
              type="button"
              class:list={[
                "diary-card-panel-text w-full text-left px-3 py-2 text-sm rounded-lg hover:text-(--primary) hover:bg-(--btn-plain-bg-hover) post-card-action-btn transition-colors",
                {
                  hidden: !viewerState.canDeleteAdmin,
                },
              ]}
              data-action="delete-admin-diary"
            >
              删除此日记(管理员)
            </button>
          </div>
        </details>
      </div>
    </div>
  </div>
</div>
<div
  class="transition border-t border-dashed mx-6 border-black/10 dark:border-white/15 last:border-t-0 hidden"
>
</div>

<style>
  .diary-card-primary-text {
    color: rgb(0 0 0 / 0.9);
  }

  .diary-card-secondary-text {
    color: rgb(0 0 0 / 0.6);
  }

  .diary-card-muted-text {
    color: rgb(0 0 0 / 0.5);
  }

  .diary-card-panel-text {
    color: rgb(0 0 0 / 0.75);
  }

  :global(:root.dark) .diary-card-primary-text {
    color: rgb(255 255 255 / 0.9);
  }

  :global(:root.dark) .diary-card-secondary-text {
    color: rgb(255 255 255 / 0.6);
  }

  :global(:root.dark) .diary-card-muted-text {
    color: rgb(255 255 255 / 0.5);
  }

  :global(:root.dark) .diary-card-panel-text {
    color: rgb(255 255 255 / 0.75);
  }

  .post-card-menu summary::-webkit-details-marker {
    display: none;
  }

  @media (max-width: 639px) {
    .diary-card-action-control {
      gap: 0.375rem;
      height: 1.25rem;
      font-size: 0.875rem;
    }

    .diary-card-action-icon {
      font-size: 1rem;
    }

    .diary-card-action-menu {
      width: 1.75rem;
      height: 1.75rem;
    }
  }

  @media (max-width: 1279px) {
    .diary-card-body {
      padding: 1rem;
    }

    .diary-card-excerpt {
      font-size: 0.875rem;
      line-height: 1.5rem;
    }

    .diary-card-meta {
      font-size: 0.75rem;
      line-height: 1.25rem;
    }
  }

  @media (min-width: 640px) and (max-width: 1279px) {
    .diary-card-body {
      padding: 1.25rem;
    }

    .diary-card-meta {
      font-size: 0.875rem;
      line-height: 1;
    }
  }
</style>
