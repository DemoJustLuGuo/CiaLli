---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";

export interface Props {
  encryptedContent: string;
  viewerIsOwner?: boolean;
  ownerPasswordStorageKeys?: string[];
}

const {
  encryptedContent,
  viewerIsOwner = false,
  ownerPasswordStorageKeys = [],
} = Astro.props;
---

<div
  id="password-protection"
  class="password-protection"
  data-viewer-is-owner={viewerIsOwner ? "1" : "0"}
  data-owner-password-storage-keys={JSON.stringify(ownerPasswordStorageKeys)}
>
  <div class="password-container">
    <div class="lock-icon">
      <svg
        width="48"
        height="48"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        class="w-12 h-12"
      >
        <path
          d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM9 6c0-1.66 1.34-3 3-3s3 1.34 3 3v2H9V6z"
          fill="currentColor"></path>
      </svg>
    </div>
    <h2>{i18n(I18nKey.contentPasswordProtectedTitle)}</h2>
    <p>{i18n(I18nKey.contentPasswordProtectedDescription)}</p>
    <div class="password-input-group">
      <input
        type="password"
        id="password-input"
        placeholder={i18n(I18nKey.contentPasswordPlaceholder)}
        class="password-input"
        aria-label={i18n(I18nKey.contentPasswordPlaceholder)}
      />
      <button id="unlock-btn" class="unlock-button"
        >{i18n(I18nKey.contentPasswordUnlock)}</button
      >
    </div>
    <div id="error-message" class="error-message" style="display: none;">
      {i18n(I18nKey.contentPasswordIncorrect)}
    </div>
  </div>
</div>

<div
  id="decrypted-content"
  class="decrypted-content w-full"
  style="display: none;"
>
  <div
    id="decrypted-content-body"
    data-mermaid-interactive="true"
    class="prose prose-base dark:prose-invert max-w-none! custom-md markdown-content"
  >
  </div>
</div>

<style>
  .password-protection {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 60vh;
    padding: 2rem;
  }

  .password-container {
    text-align: center;
    max-width: 25rem;
    width: 100%;
    padding: 2rem;
    border-radius: 12px;
    background: transparent;
    border: 1px solid var(--line-divider);
    box-shadow: none;
  }

  .lock-icon {
    display: flex;
    justify-content: center;
    margin-bottom: 1rem;
    color: var(--primary);
  }

  .lock-icon svg {
    width: 3rem;
    height: 3rem;
  }

  .password-container h2 {
    margin-bottom: 0.5rem;
    color: rgba(0, 0, 0, 0.85);
    font-size: 1.5rem;
  }

  :global(html.dark) .password-container h2 {
    color: rgba(255, 255, 255, 0.85);
  }

  .password-container p {
    margin-bottom: 1.5rem;
    color: rgba(0, 0, 0, 0.75);
    opacity: 0.8;
  }

  :global(html.dark) .password-container p {
    color: rgba(255, 255, 255, 0.75);
  }

  .password-input-group {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
    align-items: stretch;
  }

  .password-input {
    flex: 1;
    min-width: 0;
    padding: 0.75rem 1rem;
    border: 1px solid var(--line-divider);
    border-radius: 8px;
    background: transparent;
    color: rgba(0, 0, 0, 0.85);
    font-size: 1rem;
    transition: border-color 0.2s ease;
  }

  :global(html.dark) .password-input {
    color: rgba(255, 255, 255, 0.85);
  }

  .password-input::placeholder {
    color: rgba(0, 0, 0, 0.5);
  }

  :global(html.dark) .password-input::placeholder {
    color: rgba(255, 255, 255, 0.5);
  }

  .password-input:focus {
    outline: none;
    border-color: var(--primary);
  }

  .unlock-button {
    padding: 0.75rem 1.5rem;
    background: transparent;
    color: var(--primary);
    border: 1px solid var(--primary);
    border-radius: 8px;
    font-size: 1rem;
    cursor: pointer;
    transition:
      border-color 0.2s,
      color 0.2s,
      background 0.2s;
    white-space: nowrap;
    flex-shrink: 0;
    min-width: fit-content;
    max-width: max-content;
  }

  .unlock-button:hover {
    background: var(--primary);
    color: white;
    border-color: var(--primary);
  }

  .unlock-button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .error-message {
    color: #ef4444;
    font-size: 0.875rem;
    margin-top: 0.5rem;
  }

  .decrypted-content {
    animation: fadeIn 0.3s ease-in-out;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  :global(#decrypted-content .table-wrapper) {
    overflow-x: auto !important;
    width: 100% !important;
  }

  :global(#decrypted-content table) {
    display: table !important;
    width: 100% !important;
  }

  :global(.encrypted-hidden) {
    display: none !important;
  }

  :global(.encrypted-hidden-wrapper.encrypted-hidden) {
    display: none !important;
  }

  @media (min-width: 769px) {
    .password-input-group {
      flex-wrap: nowrap;
    }

    .unlock-button {
      max-width: 40%;
    }
  }
</style>

<script
  is:inline
  data-astro-rerun
  define:vars={{
    encryptedContent,
    i18nUnlocking: i18n(I18nKey.contentPasswordUnlocking),
    i18nIncorrect: i18n(I18nKey.contentPasswordIncorrect),
    i18nUnlock: i18n(I18nKey.contentPasswordUnlock),
    i18nPasswordRequired: i18n(I18nKey.contentPasswordRequired),
    i18nDecryptionError: i18n(I18nKey.contentDecryptionError),
    i18nPasswordDecryptRetry: i18n(I18nKey.contentPasswordDecryptRetry),
  }}
>
  function normalizeOwnerStorageKeys(rawKeys) {
    if (!Array.isArray(rawKeys)) {
      return [];
    }
    return rawKeys
      .map((key) => String(key || "").trim())
      .filter((key) => Boolean(key));
  }

  function isPasswordInvalidError(error) {
    if (error instanceof DOMException && error.name === "OperationError") {
      return true;
    }
    if (!(error instanceof Error)) {
      return false;
    }
    return error.message === "PASSWORD_INVALID";
  }

  function readOwnerStoredPassword(keys, isViewerOwner) {
    if (!isViewerOwner || keys.length === 0) {
      return "";
    }
    try {
      for (const key of keys) {
        const normalized = String(sessionStorage.getItem(key) || "").trim();
        if (normalized) {
          return normalized;
        }
      }
    } catch (e) {
      console.warn("[password-protection] read owner password failed:", e);
    }
    return "";
  }

  function persistOwnerStoredPassword(keys, password, isViewerOwner) {
    if (!isViewerOwner || keys.length === 0) {
      return;
    }
    const normalized = String(password || "").trim();
    if (!normalized) {
      return;
    }
    try {
      for (const key of keys) {
        sessionStorage.setItem(key, normalized);
      }
    } catch (e) {
      console.warn("[password-protection] persist owner password failed:", e);
    }
  }

  function clearOwnerStoredPassword(keys, isViewerOwner) {
    if (!isViewerOwner || keys.length === 0) {
      return;
    }
    try {
      for (const key of keys) {
        sessionStorage.removeItem(key);
      }
    } catch (e) {
      console.warn("[password-protection] clear owner password failed:", e);
    }
  }

  function resolveStoredPassword(ownerStorageKeys, isViewerOwner) {
    const pathPassword = String(
      sessionStorage.getItem("page-password-" + window.location.pathname) || "",
    ).trim();
    const ownerPassword = readOwnerStoredPassword(
      ownerStorageKeys,
      isViewerOwner,
    );
    return isViewerOwner
      ? ownerPassword || pathPassword
      : pathPassword || ownerPassword;
  }

  function applyAutoUnlockingState(protectionDiv, savedPassword) {
    if (!savedPassword) {
      return;
    }
    const inputGroup = protectionDiv.querySelector(".password-input-group");
    if (inputGroup) {
      inputGroup.style.visibility = "hidden";
    }
    const hint = protectionDiv.querySelector(".password-container p");
    if (hint) {
      hint.setAttribute("data-original-text", hint.textContent);
      hint.textContent = i18nUnlocking;
    }
    protectionDiv.classList.add("auto-unlocking");
  }

  function rollbackAutoUnlockState(
    protectionDiv,
    savedPassword,
    ownerStorageKeys,
    isViewerOwner,
    passwordInput,
  ) {
    if (!savedPassword) {
      return;
    }
    sessionStorage.removeItem("page-password-" + window.location.pathname);
    clearOwnerStoredPassword(ownerStorageKeys, isViewerOwner);
    const inputGroup = protectionDiv.querySelector(".password-input-group");
    if (inputGroup instanceof HTMLElement) {
      inputGroup.style.visibility = "visible";
    }
    const hint = protectionDiv.querySelector(".password-container p");
    if (
      hint instanceof HTMLElement &&
      hint.hasAttribute("data-original-text")
    ) {
      hint.textContent = hint.getAttribute("data-original-text");
    }
    passwordInput.value = "";
    protectionDiv.classList.remove("auto-unlocking");
  }

  async function initPasswordProtection() {
    const protectionDiv = document.getElementById("password-protection");
    if (!(protectionDiv instanceof HTMLElement)) {
      return;
    }
    if (protectionDiv.dataset.passwordProtectionInited === "1") {
      return;
    }

    const isViewerOwner = protectionDiv.dataset.viewerIsOwner === "1";
    let ownerStorageKeys = [];
    try {
      ownerStorageKeys = normalizeOwnerStorageKeys(
        JSON.parse(protectionDiv.dataset.ownerPasswordStorageKeys || "[]"),
      );
    } catch (e) {
      void e;
    }

    const savedPassword = resolveStoredPassword(
      ownerStorageKeys,
      isViewerOwner,
    );
    applyAutoUnlockingState(protectionDiv, savedPassword);

    const passwordInput = document.getElementById("password-input");
    const unlockBtn = document.getElementById("unlock-btn");
    const errorMessage = document.getElementById("error-message");
    const contentDiv = document.getElementById("decrypted-content");
    const contentBodyDiv = document.getElementById("decrypted-content-body");
    if (
      !(passwordInput instanceof HTMLInputElement) ||
      !(unlockBtn instanceof HTMLButtonElement) ||
      !(errorMessage instanceof HTMLElement) ||
      !(contentDiv instanceof HTMLElement) ||
      !(contentBodyDiv instanceof HTMLElement)
    ) {
      return;
    }
    protectionDiv.dataset.passwordProtectionInited = "1";

    function showError(message) {
      errorMessage.textContent = message;
      errorMessage.style.display = "block";
      if (!protectionDiv.classList.contains("auto-unlocking")) {
        passwordInput.focus();
      }
    }

    async function attemptUnlock() {
      const inputPassword = passwordInput.value.trim() || savedPassword;
      if (!inputPassword) {
        showError(i18nPasswordRequired);
        return;
      }
      unlockBtn.disabled = true;
      unlockBtn.textContent = i18nUnlocking;
      errorMessage.style.display = "none";
      try {
        const realContent = await window.__ppDecryptPayloadV2(
          encryptedContent,
          inputPassword,
        );
        const safeHtml = window.__ppSanitizeDecryptedHtml(
          window.__ppResolveProtectedHtml(realContent),
        );
        contentBodyDiv.innerHTML = safeHtml;
        contentDiv.style.display = "block";
        const shareEl = document.getElementById("share-component");
        const licenseEl = document.getElementById("license-component");
        if (shareEl) shareEl.classList.remove("encrypted-hidden");
        if (licenseEl) licenseEl.classList.remove("encrypted-hidden");
        if (protectionDiv.parentNode) {
          protectionDiv.remove();
        }
        sessionStorage.setItem(
          "page-password-" + window.location.pathname,
          inputPassword,
        );
        persistOwnerStoredPassword(
          ownerStorageKeys,
          inputPassword,
          isViewerOwner,
        );
        setTimeout(async () => {
          await window.__ppDispatchPostDecryptTasks(contentBodyDiv);
        }, 50);
      } catch (error) {
        if (isPasswordInvalidError(error)) {
          showError(i18nIncorrect);
          rollbackAutoUnlockState(
            protectionDiv,
            savedPassword,
            ownerStorageKeys,
            isViewerOwner,
            passwordInput,
          );
          return;
        }
        rollbackAutoUnlockState(
          protectionDiv,
          savedPassword,
          ownerStorageKeys,
          isViewerOwner,
          passwordInput,
        );
        console.error(i18nDecryptionError, error);
        showError(i18nPasswordDecryptRetry);
      } finally {
        unlockBtn.disabled = false;
        unlockBtn.textContent = i18nUnlock;
      }
    }

    unlockBtn.addEventListener("click", () => {
      void attemptUnlock();
    });
    passwordInput.addEventListener("keypress", (e) => {
      if (e.key === "Enter") {
        void attemptUnlock();
      }
    });

    if (savedPassword) {
      void attemptUnlock();
    } else {
      passwordInput.focus();
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initPasswordProtection);
  } else {
    initPasswordProtection();
  }
</script>

<script>
  import "@/scripts/password-protection-page";
</script>
