---
import PostCard from "@components/PostCard.astro";
import DiaryCard from "@/components/DiaryCard.astro";
import type { HomeFeedItem } from "@/server/recommendation/home-feed.types";
import { resolveAuthorIdentity } from "@/utils/author-identity";
import { formatDateToYYYYMMDD } from "@utils/date-utils";
import { widgetManager } from "@utils/widget-manager";

interface Props {
  items: HomeFeedItem[];
  maxAnimationIndex?: number;
}

const { items, maxAnimationIndex } = Astro.props;

const hasRightSidebars =
  widgetManager.getComponentsByPosition("top", "right").length > 0 ||
  widgetManager.getComponentsByPosition("sticky", "right").length > 0;
---

<div
  id="post-list-container"
  class="transition-all duration-500 ease-in-out rounded-(--radius-large) bg-(--card-bg) bg-transparent mb-4 list-mode"
  data-both-sidebars={hasRightSidebars}
>
  {
    items.map((item, index) => {
      const date = formatDateToYYYYMMDD(item.publishedAt);
      const [year, month] = date.split("-");
      const monthKey = `${year}-${month}`;
      const authorSource =
        item.type === "article" ? item.entry.data.author : item.entry.author;
      const authorId =
        item.type === "article"
          ? item.entry.data.author_id
          : item.entry.author_id;
      const { username: authorHandle } = resolveAuthorIdentity(
        {
          id: authorSource?.id,
          name: authorSource?.name,
          username: authorSource?.username,
          display_name: authorSource?.display_name,
        },
        authorId,
      );

      const tags = item.type === "article" ? item.entry.data.tags || [] : [];
      const category =
        item.type === "article" ? item.entry.data.category || "" : "";
      const animationIndex =
        maxAnimationIndex !== undefined
          ? Math.min(index, maxAnimationIndex)
          : index;

      return (
        <div
          class:list={[
            "post-list-item",
            {
              "diary-list-item": item.type === "diary",
            },
          ]}
          style={`--i: ${animationIndex}; --interval: 50ms;`}
          data-year={year}
          data-month={monthKey}
          data-day={date}
          data-tags={JSON.stringify(tags)}
          data-category={category}
          data-author-id={authorId}
          data-author-handle={authorHandle}
          data-content-type={item.type}
        >
          {item.type === "article" ? (
            <PostCard entry={item.entry} class:list="onload-animation" />
          ) : (
            <DiaryCard
              entry={item.entry}
              username={authorHandle}
              class:list="onload-animation"
            />
          )}
        </div>
      );
    })
  }
</div>

<script>
  import { initPostInteractions } from "@/scripts/post-interactions";

  initPostInteractions();
</script>

<style>
  @reference "../../styles/main.css";

  #post-list-container {
    min-height: 200px;
    transition: opacity 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #post-list-container.list-mode {
    @apply flex flex-col gap-4;
  }

  #post-list-container > :global(*) {
    content-visibility: auto;
    contain-intrinsic-size: 200px;
    opacity: 1;
    transform: none;
  }
</style>
