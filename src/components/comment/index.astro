    overflow: hidden;
  }

  .comment-editor-overlay {
    position: fixed;
    inset: 0;
    z-index: 9998;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    background: rgba(0, 0, 0, 0.5);
  }

  .comment-editor-overlay.hidden {
    display: none !important;
  }

  .comment-editor-overlay-card {
    width: min(100%, 920px);
    max-height: min(92vh, 980px);
    overflow-y: auto;
    border: 1px solid var(--line-divider);
    padding: clamp(1rem, 2vw, 1.25rem);
    border-radius: clamp(1rem, 2vw, var(--radius-large));
  }

  #comment-root .custom-md img {
    width: 30%;
    max-width: 30%;
    height: auto;
  }

  #comment-root .comment-node-child {
    margin-top: 0.75rem;
    margin-left: 2rem;
    padding-left: 1rem;
    border-left: 1px solid var(--line-divider);
  }
</style>
